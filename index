/* ============================================================
   SETTINGS MODULE
============================================================ */
const Settings = {
  _key: 'clib_settings',
  _current: { darkMode:false, accent:'blue', fontSize:'md', hiddenCols:[], librarian:'' },

  get() { return this._current; },

  save(s) { 
    this._current = s; 
    Store.save(); 
  },

  setAccent(accent, persist = true) {
    document.documentElement.setAttribute('data-accent', accent);
    document.querySelectorAll('.swatch').forEach(s => s.classList.toggle('active', s.dataset.accent === accent));
    if (persist) { const s = this.get(); s.accent = accent; this.save(s); }
  },

  setFontSize(size, persist = true) {
    document.body.classList.remove('font-sm','font-md','font-lg');
    document.body.classList.add(`font-${size}`);
    document.querySelectorAll('.font-size-btn').forEach(b => b.classList.toggle('active', b.dataset.size===size));
    if (persist) { const s = this.get(); s.fontSize = size; this.save(s); }
  },

  toggleColumn(col, el, hide = false) {
    const s = this.get();
    if (!s.hiddenCols) s.hiddenCols = [];

    if (hide) {
      if (!s.hiddenCols.includes(col)) s.hiddenCols.push(col);
      Books._hiddenCols = s.hiddenCols;
    } else {
      const idx = s.hiddenCols.indexOf(col);
      if (idx > -1) s.hiddenCols.splice(idx, 1);
      else s.hiddenCols.push(col);
      Books._hiddenCols = s.hiddenCols;
      if (el) el.classList.toggle('active', !s.hiddenCols.includes(col));
    }

    document.querySelectorAll('[data-col]').forEach(t => {
      if (!t.classList.contains('col-toggle')) return;
      t.classList.toggle('active', !s.hiddenCols.includes(t.dataset.col));
    });

    const hiddenCols = s.hiddenCols;
    document.querySelectorAll('#books-table th, #books-table td').forEach(cell => {
      const c = cell.dataset.col;
      if (c && c !== 'actions') cell.style.display = hiddenCols.includes(c) ? 'none' : '';
    });

    this.save(s);
    if (UI.currentPage === 'books') Books.renderTable();
  },

  saveLibrarian(val) {
    const s = this.get(); s.librarian = val; this.save(s);
  },

  _editIdx: null,

  renderCategories() {
    const tbody = document.getElementById('mgmt-categories-tbody');
    if (!tbody) return;
    if (!Store.categories.length) {
      tbody.innerHTML = `<tr><td colspan="3" class="text-center text-muted">لا توجد تصنيفات مضافة</td></tr>`;
      return;
    }
    tbody.innerHTML = Store.categories.map((c, idx) => `
      <tr>
        <td class="fw-bold">${escHtml(c.name)}</td>
        <td><span class="badge badge-secondary">${escHtml(c.letter)}</span></td>
        <td style="text-align:center">
          <button class="btn btn-xs btn-warning" onclick="Settings.editCategory(${idx})" style="padding:4px 8px; margin-left:4px" title="تعديل"><i class="fas fa-edit"></i></button>
          <button class="btn btn-xs btn-danger" onclick="Settings.deleteCategory(${idx})" style="padding:4px 8px" title="حذف"><i class="fas fa-trash"></i></button>
        </td>
      </tr>
    `).join('');
  },

  editCategory(idx) {
    const cat = Store.categories[idx];
    if (!cat) return;
    this._editIdx = idx;
    
    const nameInput   = document.getElementById('mgmt-cat-name');
    const letterInput = document.getElementById('mgmt-cat-letter');
    if (nameInput) nameInput.value = cat.name;
    if (letterInput) letterInput.value = cat.letter;
    
    const form = document.getElementById('category-mgmt-form');
    const btn = form?.querySelector('button[type="submit"]');
    if (btn) btn.innerHTML = '<i class="fas fa-save"></i> حفظ التعديل';
    nameInput?.focus();
  },

  addCategory(e) {
    e.preventDefault();
    const nameInput   = document.getElementById('mgmt-cat-name');
    const letterInput = document.getElementById('mgmt-cat-letter');
    if (!nameInput || !letterInput) return;

    const name   = nameInput.value.trim();
    const letter = letterInput.value.trim().toUpperCase();

    if (!name || !letter) return;

    if (this._editIdx !== null && this._editIdx !== undefined) {
      const oldCat = Store.categories[this._editIdx];
      // Propagate category name updates to existing books
      Store.books.forEach(b => {
        if (b.category === oldCat.name) {
          b.category = name;
        }
      });
      Store.categories[this._editIdx] = { name, letter };
      this._editIdx = null;
      
      const btn = document.getElementById('category-mgmt-form')?.querySelector('button[type="submit"]');
      if (btn) btn.innerHTML = '<i class="fas fa-plus"></i> إضافة';
      Toast.success('تم تعديل التصنيف بنجاح');
    } else {
      const dup = Store.categories.find(c => c.name.toLowerCase() === name.toLowerCase() || c.letter.toUpperCase() === letter);
      if (dup) {
        Toast.error('هذا التصنيف أو الاختصار موجود بالفعل!');
        return;
      }
      Store.categories.push({ name, letter });
      Toast.success('تمت إضافة التصنيف بنجاح');
    }

    Storage.set('clib_custom_categories', Store.categories);
    Store.rebuildCategoryMaps();
    Store.save(); // Save book category updates if any
    
    nameInput.value = '';
    letterInput.value = '';
    
    this.renderCategories();
    Books.buildCategoryDropdowns();
    if (UI.currentPage === 'books') Books.render();
  },

  deleteCategory(idx) {
    const cat = Store.categories[idx];
    if (!cat) return;
    
    const count = Store.books.filter(b => b.category === cat.name).length;
    let msg = `هل أنت متأكد من حذف تصنيف "<strong>${escHtml(cat.name)}</strong>"؟`;
    if (count > 0) {
      msg += `<br><br><strong class="text-danger">تنبيه:</strong> هناك <strong>${count}</strong> كتب مسجلة تحت هذا التصنيف حالياً!`;
    }

    Modal.confirm(msg, () => {
      Store.categories.splice(idx, 1);
      Storage.set('clib_custom_categories', Store.categories);
      Store.rebuildCategoryMaps();
      this.renderCategories();
      Books.buildCategoryDropdowns();
      Toast.success('تم حذف التصنيف');
    });
  },

  exportSettings() {
    const s = this.get();
    download(JSON.stringify(s, null, 2), `إعدادات_المكتبة_${dateStamp()}.json`, 'application/json');
    Toast.success('تم تصدير الإعدادات');
  },

  importSettings(e) {
    const file = e.target.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const s = JSON.parse(ev.target.result);
        this.save(s);
        Toast.success('تم استيراد الإعدادات');
        UI.loadSettings();
        if (UI.currentPage === 'settings') UI.navigate('settings');
      } catch { Toast.error('خطأ في قراءة ملف الإعدادات'); }
    };
    reader.readAsText(file);
    e.target.value = '';
  }
};

/* ============================================================
   HELPERS
============================================================ */
function escHtml(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}

function formatDate(d) {
  if (!d) return '—';
  try {
    const date = new Date(d);
    if (isNaN(date)) return String(d);
    return date.toLocaleDateString('ar-EG', { year:'numeric', month:'short', day:'numeric' });
  } catch { return String(d); }
}

function dateStamp() {
  return new Date().toISOString().slice(0,10);
}

function loanStatusBadge(status) {
  const map = { borrowed:'badge-warning', returned:'badge-success', overdue:'badge-danger' };
  const txt = { borrowed:'معار', returned:'تم الإرجاع', overdue:'متأخر' };
  const icon= { borrowed:'fa-handshake', returned:'fa-check-circle', overdue:'fa-clock' };
  return `<span class="badge ${map[status]||'badge-secondary'}"><i class="fas ${icon[status]||'fa-circle'}"></i> ${txt[status]||status}</span>`;
}

function loanStatusText(status) {
  return { borrowed:'معار', returned:'تم الإرجاع', overdue:'متأخر' }[status] || status;
}

function download(content, filename, mimeType) {
  const blob = content instanceof Blob ? content : new Blob([content], { type: mimeType });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url; a.download = filename;
  document.body.appendChild(a); a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

/* ============================================================
   BOOTSTRAP
============================================================ */
document.addEventListener('DOMContentLoaded', async () => {
  Loader.show('جاري تحميل البيانات من Google Sheets...');
  try {
    await UI.init();

    const lastSearch = Storage.get('clib_last_books_search', '');
    if (lastSearch) {
      const el = document.getElementById('books-search');
      if (el) el.value = lastSearch;
    }

    const lastSort = Storage.get('clib_last_books_sort', null);
    if (lastSort) { Books._sortCol = lastSort.col; Books._sortDir = lastSort.dir; }

    const s = Settings.get();
    const libEl = document.getElementById('default-librarian');
    if (libEl && s.librarian) libEl.value = s.librarian;
  } catch (err) {
    console.error('Bootstrap error:', err);
    Toast.show('فشل في بدء البرنامج. يرجى إعادة المحاولة.', 'danger');
  } finally {
    Loader.hide();
  }
});
</script>
