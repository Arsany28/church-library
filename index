const Books = {
  _filtered:  [],
  _sortCol:   'num',
  _sortDir:   'asc',
  _page:      1,
  _pageSize:  20,
  _editId:    null,
  _hiddenCols: [],

  render() {
    this.buildFilters();
    this.applyFilters();
  },

  buildCategoryDropdowns() {
    const bookCat = document.getElementById('book-category');
    const filterCat = document.getElementById('filter-category');
    if (bookCat) {
      const val = bookCat.value;
      bookCat.innerHTML = '<option value="">اختر التصنيف...</option>' + Store.categories.map(c => `
        <option value="${escHtml(c.name)}">${escHtml(c.name)} (${escHtml(c.letter)})</option>
      `).join('');
      bookCat.value = val;
    }
    if (filterCat) {
      const val = filterCat.value;
      filterCat.innerHTML = '<option value="">كل التصنيفات</option>' + Store.categories.map(c => `
        <option value="${escHtml(c.name)}">${escHtml(c.name)}</option>
      `).join('');
      filterCat.value = val;
    }
  },

  buildFilters() {
    const authors = [...new Set(Store.books.map(b => b.author).filter(Boolean))].sort();
    const authSel = document.getElementById('filter-author');
    if (!authSel) return;
    const authVal = authSel.value;
    authSel.innerHTML = '<option value="">كل المؤلفين</option>' + authors.map(a => `<option value="${escHtml(a)}">${escHtml(a)}</option>`).join('');
    authSel.value = authVal;
  },

  applyFilters() {
    const q      = (document.getElementById('books-search')?.value || '').toLowerCase().trim();
    const cat    = document.getElementById('filter-category')?.value || '';
    const author = document.getElementById('filter-author')?.value || '';
    const status = document.getElementById('filter-status')?.value || '';

    this._filtered = Store.books.filter(b => {
      const matchQ = !q || [b.num, b.title, b.author, b.category, b.letter]
                           .some(f => (f||'').toLowerCase().includes(q));
      const matchCat    = !cat    || b.category === cat;
      const matchAuthor = !author || b.author   === author;
      const matchStatus = !status || (status === 'available' ? b.available > 0 : b.available <= 0);
      return matchQ && matchCat && matchAuthor && matchStatus;
    });

    const dir = this._sortDir === 'asc' ? 1 : -1;
    const col = this._sortCol;
    this._filtered.sort((a, b) => {
      const av = (a[col] || '').toString().toLowerCase();
      const bv = (b[col] || '').toString().toLowerCase();
      return av < bv ? -dir : av > bv ? dir : 0;
    });

    this._page = 1;
    this.renderTable();
    this.renderPagination();
    const cnt = document.getElementById('books-count');
    if (cnt) cnt.textContent = `${this._filtered.length} نتيجة`;

    Storage.set('clib_last_books_search', document.getElementById('books-search')?.value || '');
  },

  sort(col) {
    if (this._sortCol === col) this._sortDir = this._sortDir === 'asc' ? 'desc' : 'asc';
    else { this._sortCol = col; this._sortDir = 'asc'; }
    document.querySelectorAll('#books-table th').forEach(th => {
      th.classList.remove('sort-asc', 'sort-desc');
      if (th.dataset.col === col) th.classList.add(this._sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
    });
    this.applyFilters();
    Storage.set('clib_last_books_sort', { col, dir: this._sortDir });
  },

  renderTable() {
    const start = (this._page - 1) * this._pageSize;
    const page  = this._filtered.slice(start, start + this._pageSize);
    const tbody = document.getElementById('books-tbody');
    if (!tbody) return;

    const visibleCols = this._hiddenCols;

    if (!page.length) {
      tbody.innerHTML = `<tr><td colspan="9"><div class="empty-state"><i class="fas fa-search"></i><p>لا توجد نتائج</p></div></td></tr>`;
      return;
    }

    tbody.innerHTML = page.map(b => {
      const isAvail = b.available > 0;
      return `<tr>
        ${this._col('num',       escHtml(b.num), visibleCols)}
        ${this._col('title',     `<span class="fw-bold">${escHtml(b.title)}</span>`, visibleCols)}
        ${this._col('author',    escHtml(b.author), visibleCols)}
        ${this._col('category',  `<span class="badge badge-info">${escHtml(b.category)}</span>`, visibleCols)}
        ${this._col('copies',    b.copies, visibleCols)}
        ${this._col('letter',    `<span class="badge badge-secondary" style="font-size:0.85em;padding:4px 10px;letter-spacing:0.5px">${escHtml(b.letter||'—')}</span>`, visibleCols)}
        ${this._col('available', `<span class="${b.available === 0 ? 'text-danger fw-bold' : 'text-success fw-bold'}">${b.available}</span>`, visibleCols)}
        ${this._col('status',    `<span class="badge ${isAvail ? 'badge-success':'badge-danger'}">${isAvail ? '✓ متاح' : '✗ غير متاح'}</span>`, visibleCols)}
        <td class="no-print">
          <div class="table-actions">
            <button class="btn btn-xs btn-info" onclick="Books.showDetail('${b.id}')" title="تفاصيل"><i class="fas fa-eye"></i></button>
            <button class="btn btn-xs btn-warning" onclick="Books.edit('${b.id}')" title="تعديل"><i class="fas fa-edit"></i></button>
            <button class="btn btn-xs btn-secondary" onclick="Books.copyData('${b.id}')" title="نسخ"><i class="fas fa-copy"></i></button>
            <button class="btn btn-xs btn-danger" onclick="Books.delete('${b.id}')" title="حذف"><i class="fas fa-trash"></i></button>
          </div>
        </td>
      </tr>`;
    }).join('');
  },

  _col(name, content, hidden) {
    return hidden.includes(name) ? '' : `<td>${content}</td>`;
  },

  renderPagination() {
    const total     = this._filtered.length;
    const totalPages = Math.ceil(total / this._pageSize) || 1;
    const el = document.getElementById('books-pagination');
    if (!el) return;

    const start = (this._page - 1) * this._pageSize + 1;
    const end   = Math.min(this._page * this._pageSize, total);

    let pages = '';
    const range = this._pageRange(this._page, totalPages);
    range.forEach(p => {
      if (p === '...') pages += `<span class="page-btn" style="cursor:default">…</span>`;
      else pages += `<button class="page-btn ${p === this._page ? 'active':''}" onclick="Books.goPage(${p})">${p}</button>`;
    });

    el.innerHTML = `
      <div class="page-info">عرض ${start}–${end} من ${total}</div>
      <div class="page-controls">
        <button class="page-btn" onclick="Books.goPage(${this._page-1})" ${this._page===1?'disabled':''}><i class="fas fa-chevron-right"></i></button>
        ${pages}
        <button class="page-btn" onclick="Books.goPage(${this._page+1})" ${this._page===totalPages?'disabled':''}><i class="fas fa-chevron-left"></i></button>
      </div>
      <select class="page-size-select" onchange="Books.setPageSize(this.value)">
        ${[10,20,50,100].map(n => `<option value="${n}" ${n===this._pageSize?'selected':''}>${n} / صفحة</option>`).join('')}
      </select>`;
  },

  _pageRange(cur, total) {
    if (total <= 7) return Array.from({length: total}, (_,i) => i+1);
    const pages = [1];
    if (cur > 3) pages.push('...');
    for (let i = Math.max(2, cur-1); i <= Math.min(total-1, cur+1); i++) pages.push(i);
    if (cur < total - 2) pages.push('...');
    pages.push(total);
    return pages;
  },

  goPage(p) {
    const total = Math.ceil(this._filtered.length / this._pageSize) || 1;
    this._page = Math.max(1, Math.min(p, total));
    this.renderTable();
    this.renderPagination();
  },

  setPageSize(n) {
    this._pageSize = parseInt(n); this._page = 1;
    this.renderTable(); this.renderPagination();
  },

  onCategoryChange(val) {
    const code = CATEGORY_MAP[val] || '';
    const letterInput = document.getElementById('book-letter');
    if (letterInput && code) {
      let maxSuffix = 0;
      let hasMatches = false;
      let maxPaddingLength = 4;
      const cleanPrefix = code.trim().toUpperCase();
      
      Store.books.forEach(b => {
        if (b.letter) {
          const lVal = b.letter.trim().toUpperCase();
          if (lVal.startsWith(cleanPrefix)) {
            const nextChar = lVal.charAt(cleanPrefix.length);
            const isNextLetter = /^[A-Z\u0621-\u064A]/.test(nextChar);
            if (!isNextLetter) {
              // Extract the number part from the letter field
              const numPart = lVal.substring(cleanPrefix.length).replace(/[\s_-]+/g, '').trim();
              const valNum = parseInt(numPart, 10);
              if (!isNaN(valNum)) {
                hasMatches = true;
                if (valNum > maxSuffix) {
                  maxSuffix = valNum;
                  maxPaddingLength = Math.max(numPart.length, 4);
                }
              }
            }
          }
        }
      });
      
      if (hasMatches) {
        const nextVal = maxSuffix + 5;
        const padded = String(nextVal).padStart(maxPaddingLength, '0');
        letterInput.value = `${cleanPrefix}${padded}`;
      } else {
        letterInput.value = `${cleanPrefix}0005`;
      }
    }
  },

  onLetterInput(val) {
    const clean = val.trim().toLowerCase();
    // Extract alphabetical prefix or everything before space/digits
    const match = clean.match(/^([a-z\u0621-\u064A]+)/);
    const prefix = match ? match[1] : clean;
    const catSelect = document.getElementById('book-category');
    if (catSelect && REVERSE_CATEGORY_MAP[prefix]) {
      catSelect.value = REVERSE_CATEGORY_MAP[prefix];
    }
  },

  checkDuplicateNum(val) {
    const errEl = document.getElementById('book-num-error');
    const input = document.getElementById('book-num');
    const editId = document.getElementById('book-id').value;
    const v = val.trim().toLowerCase();
    if (!v) { errEl.classList.remove('show'); input.style.borderColor = ''; return; }
    const dup = Store.books.find(b => b.id !== editId && b.num.toLowerCase() === v);
    if (dup) {
      errEl.innerHTML = '<i class="fas fa-exclamation-triangle"></i> رقم الكتاب موجود بالفعل! (الكتاب: ' + escHtml(dup.title) + ')';
      errEl.classList.add('show');
      input.style.borderColor = 'var(--danger)';
    } else {
      errEl.classList.remove('show');
      input.style.borderColor = '';
    }
  },

  checkDuplicateTitle(val) {
    const errEl = document.getElementById('book-title-error');
    const input = document.getElementById('book-title');
    const editId = document.getElementById('book-id').value;
    const v = val.trim().toLowerCase();
    if (!v) { errEl.classList.remove('show'); input.style.borderColor = ''; return; }
    const dup = Store.books.find(b => b.title.toLowerCase() === v);
    if (dup && dup.id !== editId) {
      errEl.innerHTML = '<i class="fas fa-info-circle"></i> هذا الكتاب مسجل بالفعل. تم ملء بياناته تلقائياً لتعديلها.';
      errEl.classList.add('show');
      input.style.borderColor = 'var(--primary)';
      
      // Auto fill form with the existing book details
      this._editId = dup.id;
      document.getElementById('book-id').value       = dup.id;
      document.getElementById('book-num').value      = dup.num;
      document.getElementById('book-author').value   = dup.author;
      document.getElementById('book-category').value = dup.category;
      document.getElementById('book-letter').value   = dup.letter || '';
      document.getElementById('book-publisher').value= dup.publisher || '';
      document.getElementById('book-year').value     = dup.year || '';
      document.getElementById('book-copies').value   = dup.copies;
      document.getElementById('book-available').value= dup.available;
      document.getElementById('save-book-btn').innerHTML = '<i class="fas fa-edit"></i> حفظ التعديلات';
    } else {
      errEl.classList.remove('show');
      input.style.borderColor = '';
    }
  },

  save(e) {
    e.preventDefault();
    const num       = document.getElementById('book-num').value.trim();
    const title     = document.getElementById('book-title').value.trim();
    const author    = document.getElementById('book-author').value.trim();
    const category  = document.getElementById('book-category').value.trim();
    const letter    = document.getElementById('book-letter').value.trim();
    const publisher = document.getElementById('book-publisher').value.trim();
    const year      = document.getElementById('book-year').value.trim();
    const copies    = parseInt(document.getElementById('book-copies').value) || 1;
    let   available = parseInt(document.getElementById('book-available').value);
    const editId    = document.getElementById('book-id').value;

    if (isNaN(available) || available < 0) available = copies;
    if (available > copies) available = copies;

    // Strict duplicate check
    const dup = Store.books.find(b => b.id !== editId && (
      b.num.toLowerCase()    === num.toLowerCase()    ||
      b.title.toLowerCase()  === title.toLowerCase()
    ));
    if (dup) {
      let reason = b => b.num.toLowerCase() === num.toLowerCase() ? 'رقم الكتاب' : 'اسم الكتاب';
      Toast.error(`هذا الكتاب موجود بالفعل! (${reason(dup)})`);
      return;
    }

    if (editId) {
      const idx = Store.books.findIndex(b => b.id === editId);
      if (idx > -1) {
        const old = Store.books[idx];
        const copiesDiff = copies - old.copies;
        Store.books[idx] = { ...old, num, title, author, category, letter, publisher, year, copies, available: Math.max(0, old.available + copiesDiff), updatedAt: new Date().toISOString() };
        Store.save();
        Toast.success('تم تعديل بيانات الكتاب بنجاح');
      }
    } else {
      const newBook = { id: Store.genId(), num, title, author, category, letter, publisher, year, copies, available, addedAt: new Date().toISOString() };
      Store.books.push(newBook);
      Store.save();
      Toast.success('تمت إضافة الكتاب بنجاح');
    }

    this.clearForm();
    this.render();
  },

  edit(id) {
    const b = Store.getBook(id);
    if (!b) return;
    this._editId = id;
    document.getElementById('book-id').value       = id;
    document.getElementById('book-num').value      = b.num;
    document.getElementById('book-title').value    = b.title;
    document.getElementById('book-author').value   = b.author;
    document.getElementById('book-category').value = b.category;
    document.getElementById('book-letter').value   = b.letter || '';
    document.getElementById('book-publisher').value= b.publisher || '';
    document.getElementById('book-year').value     = b.year || '';
    document.getElementById('book-copies').value   = b.copies;
    document.getElementById('book-available').value= b.available;
    document.getElementById('save-book-btn').innerHTML = '<i class="fas fa-edit"></i> حفظ التعديلات';
    document.querySelector('#page-books').scrollIntoView({ behavior:'smooth' });
    document.getElementById('book-num').focus();
    Toast.info('جاهز للتعديل - عدّل البيانات ثم اضغط حفظ');
  },

  clearForm() {
    this._editId = null;
    document.getElementById('book-form').reset();
    document.getElementById('book-id').value = '';
    document.getElementById('save-book-btn').innerHTML = '<i class="fas fa-save"></i> حفظ الكتاب';
    
    // Auto-generate next book number
    let max = 0;
    Store.books.forEach(b => {
      const val = parseInt(b.num, 10);
      if (!isNaN(val) && val > max) max = val;
    });
    document.getElementById('book-num').value = max + 1;

    // Clear duplicate warnings
    ['book-num-error','book-title-error'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.remove('show');
    });
    ['book-num','book-title'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.style.borderColor = '';
    });
  },

  delete(id) {
    const b = Store.getBook(id);
    if (!b) return;
    const hasLoan = Store.loans.some(l => l.bookId === id && l.status !== 'returned');
    Modal.confirm(
      hasLoan
        ? `<strong class="text-danger">تحذير:</strong> هذا الكتاب معار حالياً!<br><br>هل أنت متأكد من حذف كتاب "<strong>${escHtml(b.title)}</strong>"؟`
        : `هل أنت متأكد من حذف كتاب "<strong>${escHtml(b.title)}</strong>"؟ لا يمكن التراجع عن هذا الإجراء.`,
      () => {
        Store.books = Store.books.filter(bk => bk.id !== id);
        Store.save();
        Toast.success('تم حذف الكتاب');
        this.render();
        Dashboard.render();
      }
    );
  },

  showDetail(id) {
    const b = Store.getBook(id);
    if (!b) return;
    const loans = Store.loans.filter(l => l.bookId === id);
    const active = loans.filter(l => l.status !== 'returned');
    Modal.show({
      title: `<i class="fas fa-book text-primary"></i> ${escHtml(b.title)}`,
      size: 'lg',
      body: `
        <div class="detail-grid">
          <div class="detail-item"><label>رقم الكتاب</label><p>${escHtml(b.num)}</p></div>
          <div class="detail-item full"><label>اسم الكتاب</label><p class="fw-bold">${escHtml(b.title)}</p></div>
          <div class="detail-item"><label>المؤلف</label><p>${escHtml(b.author)}</p></div>
          <div class="detail-item"><label>التصنيف</label><p><span class="badge badge-info">${escHtml(b.category)}</span></p></div>
          <div class="detail-item"><label>الرقم الخاص</label><p><span class="badge badge-secondary">${escHtml(b.letter||'—')}</span></p></div>
          <div class="detail-item"><label>دار النشر</label><p>${escHtml(b.publisher||'—')}</p></div>
          <div class="detail-item"><label>سنة النشر</label><p>${escHtml(b.year||'—')}</p></div>
          <div class="detail-item"><label>عدد النسخ</label><p>${b.copies}</p></div>
          <div class="detail-item"><label>النسخ المتاحة</label><p class="${b.available>0?'text-success':'text-danger'} fw-bold">${b.available}</p></div>
          <div class="detail-item"><label>الحالة</label><p><span class="badge ${b.available>0?'badge-success':'badge-danger'}">${b.available>0?'متاح':'غير متاح'}</span></p></div>
          <div class="detail-item"><label>تاريخ الإضافة</label><p>${formatDate(b.addedAt)}</p></div>
          <div class="detail-item"><label>إجمالي الاستعارة</label><p>${loans.length} مرة</p></div>
          ${active.length ? `<div class="detail-item full"><label>مستعار حالياً بواسطة</label><p class="text-warning fw-bold">${active.map(l=>escHtml(l.borrowerName)).join('، ')}</p></div>` : ''}
        </div>`,
      footer: `
        <button class="btn btn-secondary" onclick="Modal.closeAll()">إغلاق</button>
        <button class="btn btn-warning" onclick="Modal.closeAll(); Books.edit('${id}')"><i class="fas fa-edit"></i> تعديل</button>
        <button class="btn btn-primary" onclick="Print.book('${id}')"><i class="fas fa-print"></i> طباعة</button>`
    });
  },

  copyData(id) {
    const b = Store.getBook(id);
    if (!b) return;
    const text = `اسم الكتاب: ${b.title}\nالمؤلف: ${b.author}\nالتصنيف: ${b.category}\nالرقم الخاص: ${b.letter||'—'}\nرقم الكتاب: ${b.num}`;
    navigator.clipboard?.writeText(text).then(() => Toast.success('تم نسخ بيانات الكتاب')).catch(() => Toast.error('تعذّر النسخ'));
  }
};

/* ============================================================
   LOANS MODULE
============================================================ */
const Loans = {
  _filtered: [],
  _sortCol:  'loanDate',
  _sortDir:  'desc',
  _page:     1,
  _pageSize: 20,

  initBorrowForm() {
    const today  = new Date().toISOString().split('T')[0];
    const ret    = new Date(); ret.setDate(ret.getDate() + 14);
    const retStr = ret.toISOString().split('T')[0];

    const loanDateEl   = document.getElementById('loan-date');
    const returnDateEl = document.getElementById('return-date');
    if (loanDateEl)   loanDateEl.value   = today;
    if (returnDateEl) returnDateEl.value = retStr;

    const s = Settings.get();
    const lib = document.getElementById('librarian-name');
    if (lib && !lib.value && s.librarian) lib.value = s.librarian;

    this._setupBookSearch();
  },

  _setupBookSearch() {
    const input = document.getElementById('loan-book-search');
    const list  = document.getElementById('book-suggestions');
    if (!input || !list) return;

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      if (!q) { list.classList.remove('show'); return; }
      const hits = Store.books.filter(b =>
        b.title.toLowerCase().includes(q) || 
        b.num.toLowerCase().includes(q) || 
        (b.letter||'').toLowerCase().includes(q)
      ).slice(0, 8);
      list.innerHTML = hits.map(b => `
        <div class="autocomplete-item" onmousedown="Loans._selectBook('${b.id}')">
          <div style="font-weight:700">${escHtml(b.title)}</div>
          <div style="font-size:0.78rem;color:var(--text3)">${escHtml(b.num)} | ${escHtml(b.author)}${b.letter ? ' | <span style="color:var(--primary);font-weight:600">' + escHtml(b.letter) + '</span>' : ''} | متاح: <span class="${b.available>0?'text-success':'text-danger'} fw-bold">${b.available}</span>/${b.copies}</div>
        </div>`).join('') || `<div class="autocomplete-item text-muted">لا توجد نتائج</div>`;
      list.classList.add('show');
    });
    input.addEventListener('blur', () => setTimeout(() => list.classList.remove('show'), 200));
  },

  _selectBook(id) {
    const b = Store.getBook(id);
    if (!b) return;
    document.getElementById('loan-book-search').value = `${b.title} (${b.num})`;
    document.getElementById('loan-book-id').value = id;
    document.getElementById('book-suggestions').classList.remove('show');

    const preview = document.getElementById('book-preview');
    if (preview) {
      document.getElementById('preview-title').textContent = b.title;
      document.getElementById('preview-info').textContent  = `${b.author} | ${b.category} | الرقم الخاص: ${b.letter||'—'}`;
      document.getElementById('preview-status').innerHTML  = b.available > 0
        ? `<span class="badge badge-success">متاح (${b.available} نسخة)</span>`
        : `<span class="badge badge-danger">غير متاح</span>`;
      preview.style.display = 'block';
    }
  },

  suggestBorrower() {
    const q    = document.getElementById('borrower-name').value.toLowerCase().trim();
    const list = document.getElementById('borrower-suggestions');
    if (!q || q.length < 1) { list.classList.remove('show'); return; }
    const hits = Store.borrowers.filter(b => b.name.toLowerCase().includes(q)).slice(0, 6);
    list.innerHTML = hits.map(b => `
      <div class="sug-item" onmousedown="Loans._selectBorrower('${escHtml(b.name).replace(/'/g,"\\'")}', '${escHtml(b.phone)}', '${escHtml(b.service||'')}')">
        <div class="sug-name">${escHtml(b.name)}</div>
        <div class="sug-phone">${escHtml(b.phone)} ${b.service ? '| ' + escHtml(b.service) : ''}</div>
      </div>`).join('');
    list.classList.toggle('show', hits.length > 0);
  },

  _selectBorrower(name, phone, service) {
    document.getElementById('borrower-name').value    = name;
    document.getElementById('borrower-phone').value   = phone;
    document.getElementById('borrower-service').value = service;
    document.getElementById('borrower-suggestions').classList.remove('show');
  },

  suggestBook() { },

  save(e) {
    e.preventDefault();
    const name    = document.getElementById('borrower-name').value.trim();
    const phone   = document.getElementById('borrower-phone').value.trim();
    const service = document.getElementById('borrower-service').value.trim();
    const libr    = document.getElementById('librarian-name').value.trim();
    const bookId  = document.getElementById('loan-book-id').value;
    const loanDate= document.getElementById('loan-date').value;
    const retDate = document.getElementById('return-date').value;
    const notes   = document.getElementById('loan-notes').value.trim();

    if (!bookId) { Toast.error('يرجى اختيار كتاب من القائمة'); return; }
    if (!name)   { Toast.error('يرجى إدخال اسم المستعير'); return; }
    if (!phone)  { Toast.error('يرجى إدخال رقم الهاتف'); return; }

    const book = Store.getBook(bookId);
    if (!book) { Toast.error('الكتاب غير موجود'); return; }
    if (book.available <= 0) { Toast.error('عذراً، لا توجد نسخ متاحة من هذا الكتاب'); return; }

    const existing = Store.loans.find(l => l.bookId === bookId && l.borrowerName.toLowerCase() === name.toLowerCase() && l.status !== 'returned');
    if (existing) { Toast.warning('هذا الشخص يمتلك نسخة من هذا الكتاب بالفعل'); return; }

    const loan = {
      id: Store.genId(), bookId, bookTitle: book.title, bookNum: book.num,
      borrowerName: name, borrowerPhone: phone, borrowerService: service,
      librarianName: libr, loanDate, returnDate: retDate,
      actualReturnDate: '', notes, status: 'borrowed',
      createdAt: new Date().toISOString()
    };
    Store.loans.push(loan);

    book.available = Math.max(0, book.available - 1);
    Store.save();

    this._upsertBorrower(name, phone, service);

    Toast.success(`تمت الاستعارة بنجاح! الكتاب: "${book.title}"`);
    this.clearBorrowForm();
    Dashboard.render();
    UI.checkOverdueAlert();
  },

  _upsertBorrower(name, phone, service) {
    const today = new Date().toISOString().split('T')[0];
    const idx   = Store.borrowers.findIndex(b => b.name.toLowerCase() === name.toLowerCase());
    if (idx > -1) {
      Store.borrowers[idx].phone    = phone;
      Store.borrowers[idx].service  = service || Store.borrowers[idx].service;
      Store.borrowers[idx].totalLoans += 1;
      Store.borrowers[idx].lastLoan   = today;
    } else {
      Store.borrowers.push({ id: Store.genId(), name, phone, service, totalLoans: 1, lastLoan: today, createdAt: new Date().toISOString() });
    }
    Store.save();
  },

  clearBorrowForm() {
    document.getElementById('borrow-form').reset();
    document.getElementById('loan-book-id').value = '';
    const preview = document.getElementById('book-preview');
    if (preview) preview.style.display = 'none';
    this.initBorrowForm();
  },

  render() {
    this.applyFilters();
  },

  applyFilters() {
    Store.updateLoanStatuses();
    const q      = (document.getElementById('loans-search')?.value || '').toLowerCase().trim();
    const status = document.getElementById('filter-loan-status')?.value || '';

    this._filtered = Store.loans.filter(l => {
      const matchQ = !q || [l.bookTitle, l.borrowerName, l.borrowerPhone, l.librarianName, l.bookNum]
                           .some(f => (f||'').toLowerCase().includes(q));
      const matchS = !status || l.status === status;
      return matchQ && matchS;
    });

    const dir = this._sortDir === 'asc' ? 1 : -1;
    const col = this._sortCol;
    this._filtered.sort((a,b) => {
      const av = (a[col]||'').toString(); const bv = (b[col]||'').toString();
      return av < bv ? -dir : av > bv ? dir : 0;
    });

    this._page = 1;
    this.renderTable();
    this.renderPagination();
    const cnt = document.getElementById('loans-count');
    if (cnt) cnt.textContent = `${this._filtered.length} سجل`;
  },

  sort(col) {
    if (this._sortCol === col) this._sortDir = this._sortDir === 'asc' ? 'desc' : 'asc';
    else { this._sortCol = col; this._sortDir = 'asc'; }
    this.applyFilters();
  },

  renderTable() {
    const start = (this._page - 1) * this._pageSize;
    const page  = this._filtered.slice(start, start + this._pageSize);
    const tbody = document.getElementById('loans-tbody');
    if (!tbody) return;

    if (!page.length) {
      tbody.innerHTML = `<tr><td colspan="9"><div class="empty-state"><i class="fas fa-inbox"></i><p>لا توجد سجلات</p></div></td></tr>`;
      return;
    }

    tbody.innerHTML = page.map(l => `
      <tr class="${l.status === 'overdue' ? 'overdue' : ''}">
        <td><span class="fw-bold">${escHtml(l.bookTitle)}</span><br><small class="text-muted">${escHtml(l.bookNum)}</small></td>
        <td>${escHtml(l.borrowerName)}</td>
        <td dir="ltr">${escHtml(l.borrowerPhone)}</td>
        <td>${formatDate(l.loanDate)}</td>
        <td>${formatDate(l.returnDate)}</td>
        <td>${l.actualReturnDate ? formatDate(l.actualReturnDate) : '—'}</td>
        <td>${loanStatusBadge(l.status)}</td>
        <td>${escHtml(l.librarianName||'—')}</td>
        <td class="no-print">
          <div class="table-actions">
            ${l.status !== 'returned' ? `<button class="btn btn-xs btn-success" onclick="Loans.markReturned('${l.id}')" title="تسجيل إرجاع"><i class="fas fa-check"></i></button>` : ''}
            <button class="btn btn-xs btn-danger" onclick="Loans.delete('${l.id}')" title="حذف"><i class="fas fa-trash"></i></button>
          </div>
        </td>
      </tr>`).join('');
  },

  renderPagination() {
    const total      = this._filtered.length;
    const totalPages = Math.ceil(total / this._pageSize) || 1;
    const el = document.getElementById('loans-pagination');
    if (!el) return;
    const start = (this._page - 1) * this._pageSize + 1;
    const end   = Math.min(this._page * this._pageSize, total);

    const range = Books._pageRange(this._page, totalPages);
    let pages = range.map(p => p === '...'
      ? `<span class="page-btn" style="cursor:default">…</span>`
      : `<button class="page-btn ${p===this._page?'active':''}" onclick="Loans.goPage(${p})">${p}</button>`
    ).join('');

    el.innerHTML = `
      <div class="page-info">عرض ${start}–${end} من ${total}</div>
      <div class="page-controls">
        <button class="page-btn" onclick="Loans.goPage(${this._page-1})" ${this._page===1?'disabled':''}><i class="fas fa-chevron-right"></i></button>
        ${pages}
        <button class="page-btn" onclick="Loans.goPage(${this._page+1})" ${this._page===totalPages?'disabled':''}><i class="fas fa-chevron-left"></i></button>
      </div>
      <select class="page-size-select" onchange="Loans.setPageSize(this.value)">
        ${[10,20,50,100].map(n=>`<option value="${n}" ${n===this._pageSize?'selected':''}>${n} / صفحة</option>`).join('')}
      </select>`;
  },

  goPage(p) {
    const total = Math.ceil(this._filtered.length / this._pageSize) || 1;
    this._page = Math.max(1, Math.min(p, total));
    this.renderTable(); this.renderPagination();
  },

  setPageSize(n) { this._pageSize = parseInt(n); this._page = 1; this.renderTable(); this.renderPagination(); },

  markReturned(id) {
    const today = new Date().toISOString().split('T')[0];
    Modal.show({
      title: '<i class="fas fa-check-circle text-success"></i> تسجيل إرجاع الكتاب',
      size: 'sm',
      body: `
        <div class="form-group">
          <label class="form-label">تاريخ الإرجاع الفعلي</label>
          <input type="date" class="form-control" id="actual-return-date" value="${today}" max="${today}">
        </div>
        <div class="form-group">
          <label class="form-label">ملاحظات</label>
          <textarea class="form-control" id="return-notes" rows="2" placeholder="ملاحظات إرجاع..."></textarea>
        </div>`,
      footer: `
        <button class="btn btn-secondary" onclick="Modal.closeAll()">إلغاء</button>
        <button class="btn btn-success" onclick="Loans._confirmReturn('${id}')"><i class="fas fa-check"></i> تأكيد الإرجاع</button>`
    });
  },

  _confirmReturn(id) {
    const loan = Store.getLoan(id);
    if (!loan) return;
    const date  = document.getElementById('actual-return-date')?.value || new Date().toISOString().split('T')[0];
    const notes = document.getElementById('return-notes')?.value || '';
    loan.actualReturnDate = date;
    loan.status = 'returned';
    if (notes) loan.notes = (loan.notes ? loan.notes + ' | ' : '') + 'إرجاع: ' + notes;

    const book = Store.getBook(loan.bookId);
    if (book) { book.available = Math.min(book.copies, book.available + 1); }

    Store.save();
    Modal.closeAll();
    Toast.success(`تم تسجيل إرجاع "${loan.bookTitle}" بنجاح`);
    this.render();
    Dashboard.render();
    UI.checkOverdueAlert();
  },

  delete(id) {
    const l = Store.getLoan(id);
    if (!l) return;
    Modal.confirm(`هل تريد حذف سجل استعارة "<strong>${escHtml(l.bookTitle)}</strong>" للمستعير "<strong>${escHtml(l.borrowerName)}</strong>"؟`, () => {
      if (l.status !== 'returned') {
        const book = Store.getBook(l.bookId);
        if (book) book.available = Math.min(book.copies, book.available + 1);
      }
      Store.loans = Store.loans.filter(ln => ln.id !== id);
      Store.save();
      Toast.success('تم حذف السجل');
      this.render();
      Dashboard.render();
      UI.checkOverdueAlert();
    });
  }
};

/* ============================================================
   BORROWERS MANAGER
============================================================ */
const BorrowersMgr = {
  _filtered: [],
  _page: 1,
  _pageSize: 20,

  render() { this.applyFilters(); },

  applyFilters() {
    const q = (document.getElementById('borrowers-search')?.value || '').toLowerCase().trim();
    this._filtered = Store.borrowers.filter(b => !q || b.name.toLowerCase().includes(q) || b.phone.includes(q));
    this._filtered.sort((a,b) => a.name.localeCompare(b.name, 'ar'));
    this._page = 1;
    this.renderTable();
    this.renderPagination();
    const cnt = document.getElementById('borrowers-count');
    if (cnt) cnt.textContent = `${this._filtered.length} مستعير`;
  },

  renderTable() {
    const start = (this._page - 1) * this._pageSize;
    const page  = this._filtered.slice(start, start + this._pageSize);
    const tbody = document.getElementById('borrowers-tbody');
    if (!tbody) return;
    if (!page.length) {
      tbody.innerHTML = `<tr><td colspan="7"><div class="empty-state"><i class="fas fa-users"></i><p>لا يوجد مستعيرون</p></div></td></tr>`;
      return;
    }

    tbody.innerHTML = page.map(b => {
      const activeLoans = Store.loans.filter(l => l.borrowerName.toLowerCase() === b.name.toLowerCase() && l.status !== 'returned').length;
      return `<tr>
        <td class="fw-bold">${escHtml(b.name)}</td>
        <td dir="ltr">${escHtml(b.phone)}</td>
        <td>${escHtml(b.service||'—')}</td>
        <td><span class="badge ${activeLoans>0?'badge-warning':'badge-secondary'}">${activeLoans}</span></td>
        <td>${b.totalLoans}</td>
        <td>${formatDate(b.lastLoan)}</td>
        <td class="no-print">
          <div class="table-actions">
            <button class="btn btn-xs btn-info" onclick="BorrowersMgr.showDetail('${b.id}')" title="تفاصيل"><i class="fas fa-eye"></i></button>
            <button class="btn btn-xs btn-danger" onclick="BorrowersMgr.delete('${b.id}')" title="حذف"><i class="fas fa-trash"></i></button>
          </div>
        </td>
      </tr>`;
    }).join('');
  },

  renderPagination() {
    const total = this._filtered.length;
    const totalPages = Math.ceil(total / this._pageSize) || 1;
    const el = document.getElementById('borrowers-pagination');
    if (!el) return;
    const start = (this._page-1)*this._pageSize+1;
    const end   = Math.min(this._page*this._pageSize, total);
    const range = Books._pageRange(this._page, totalPages);
    let pages = range.map(p => p==='...' ? `<span class="page-btn" style="cursor:default">…</span>` : `<button class="page-btn ${p===this._page?'active':''}" onclick="BorrowersMgr.goPage(${p})">${p}</button>`).join('');
    el.innerHTML = `
      <div class="page-info">عرض ${start}–${end} من ${total}</div>
      <div class="page-controls">
        <button class="page-btn" onclick="BorrowersMgr.goPage(${this._page-1})" ${this._page===1?'disabled':''}><i class="fas fa-chevron-right"></i></button>
        ${pages}
        <button class="page-btn" onclick="BorrowersMgr.goPage(${this._page+1})" ${this._page===totalPages?'disabled':''}><i class="fas fa-chevron-left"></i></button>
      </div>`;
  },

  goPage(p) {
    const total = Math.ceil(this._filtered.length/this._pageSize)||1;
    this._page = Math.max(1,Math.min(p,total));
    this.renderTable(); this.renderPagination();
  },

  showDetail(id) {
    const b = Store.borrowers.find(x => x.id === id);
    if (!b) return;
    const loans = Store.loans.filter(l => l.borrowerName.toLowerCase() === b.name.toLowerCase());
    const active = loans.filter(l => l.status !== 'returned');
    const overdue= loans.filter(l => l.status === 'overdue');
    Modal.show({
      title: `<i class="fas fa-user text-primary"></i> ${escHtml(b.name)}`,
      size: 'lg',
      body: `
        <div class="detail-grid">
          <div class="detail-item"><label>الاسم</label><p class="fw-bold">${escHtml(b.name)}</p></div>
          <div class="detail-item"><label>الهاتف</label><p dir="ltr">${escHtml(b.phone)}</p></div>
          <div class="detail-item"><label>رقم الخدمة</label><p>${escHtml(b.service||'—')}</p></div>
          <div class="detail-item"><label>إجمالي الاستعارة</label><p>${b.totalLoans}</p></div>
          <div class="detail-item"><label>كتب حالية</label><p class="${active.length>0?'text-warning':''} fw-bold">${active.length}</p></div>
          <div class="detail-item"><label>متأخرة</label><p class="${overdue.length>0?'text-danger':''} fw-bold">${overdue.length}</p></div>
          <div class="detail-item"><label>آخر استعارة</label><p>${formatDate(b.lastLoan)}</p></div>
        </div>
        ${active.length ? `
          <h4 style="margin:16px 0 10px; font-size:0.9rem; color:var(--text2)">الكتب الحالية:</h4>
          ${active.map(l=>`<div style="padding:8px; background:var(--bg2); border-radius:6px; margin-bottom:6px; font-size:0.85rem">
            <strong>${escHtml(l.bookTitle)}</strong> — إرجاع متوقع: ${formatDate(l.returnDate)} 
            ${l.status==='overdue'?'<span class="badge badge-danger">متأخر</span>':''}
          </div>`).join('')}` : ''}`,
      footer: `<button class="btn btn-secondary" onclick="Modal.closeAll()">إغلاق</button>`
    });
  },

  delete(id) {
    const b = Store.borrowers.find(x => x.id === id);
    if (!b) return;
    const hasActive = Store.loans.some(l => l.borrowerName.toLowerCase() === b.name.toLowerCase() && l.status !== 'returned');
    if (hasActive) { Toast.error('لا يمكن حذف مستعير لديه كتب لم يُعدها بعد'); return; }
    Modal.confirm(`هل تريد حذف بيانات "<strong>${escHtml(b.name)}</strong>"؟`, () => {
      Store.borrowers = Store.borrowers.filter(x => x.id !== id);
      Store.save();
      Toast.success('تم حذف المستعير');
      this.render();
    });
  }
};

