                <br><small style="opacity:.8">الأعمدة المتاحة في الملف: ${headers.filter(Boolean).join(' | ')}</small>
              </div>` : ''}

              <div style="display:flex;gap:12px;justify-content:flex-end">
                <button onclick="document.getElementById('excel-preview-modal').remove()" style="padding:10px 24px;border:2px solid #ddd;background:#f5f5f5;border-radius:10px;cursor:pointer;font-family:Cairo,sans-serif;font-size:14px">إلغاء</button>
                <button id="confirm-excel-import" style="padding:10px 28px;background:linear-gradient(135deg,#4a6fa5,#2196f3);color:#fff;border:none;border-radius:10px;cursor:pointer;font-family:Cairo,sans-serif;font-size:14px;font-weight:700">
                  <i class="fas fa-file-import" style="margin-left:6px"></i> استيراد ${totalDataRows} كتاب
                </button>
              </div>
            </div>
          </div>`;
        document.body.appendChild(modal);
        Loader.hide();

        // ── Actual import on confirm ──
        document.getElementById('confirm-excel-import').onclick = () => {
          modal.remove();
          Loader.show('جاري الاستيراد...');
          setTimeout(() => {
            try {
              let added = 0, skipped = 0;
              const extractPrefix = (str) => {
                if (!str) return '';
                // Extract only leading letters
                const match = str.trim().match(/^([A-Za-z\u0621-\u064A]+)/);
                return match ? match[1].toUpperCase() : '';
              };

              for (let i = headerRowIdx + 1; i < rows.length; i++) {
                const r = rows[i];
                if (!r || !r.length) continue;
                const title = titleIdx !== -1 ? (r[titleIdx]||'').toString().trim() : '';
                if (!title) { skipped++; continue; }

                let num = numIdx !== -1 ? (r[numIdx]||'').toString().trim() : '';
                if (!num) {
                  let max = 0;
                  Store.books.forEach(b => { const val = parseInt(b.num,10); if (!isNaN(val) && val > max) max = val; });
                  num = String(Math.max(max, Store.books.length) + added + 1);
                }

                const dup = Store.books.find(b => b.num.toLowerCase() === num.toLowerCase() || b.title.toLowerCase() === title.toLowerCase());
                if (dup) {
                  // Update existing book's letter/category if missing
                  let updatedLetter = letterIdx !== -1 && r[letterIdx] !== undefined && r[letterIdx] !== null ? String(r[letterIdx]).trim() : '';
                  let updatedCategory = categoryIdx !== -1 ? (r[categoryIdx]||'').toString().trim() : '';
                  if (updatedLetter && !dup.letter) dup.letter = updatedLetter;
                  if (updatedCategory && !dup.category) dup.category = updatedCategory;
                  skipped++; continue;
                }

                const category = categoryIdx !== -1 ? (r[categoryIdx]||'').toString().trim() : '';
                let letter = letterIdx !== -1 && r[letterIdx] !== undefined && r[letterIdx] !== null ? String(r[letterIdx]).trim() : '';

                if (category) {
                  const prefix = extractPrefix(letter) || category.substring(0,2).toUpperCase();
                  const existingCat = Store.categories.find(c => c.name.toLowerCase() === category.toLowerCase());
                  if (existingCat) {
                    if (prefix && existingCat.letter.toUpperCase() !== prefix) { existingCat.letter = prefix; Store.rebuildCategoryMaps(); }
                  } else {
                    Store.categories.push({ name: category, letter: prefix });
                    Store.rebuildCategoryMaps();
                  }
                }

                if (!letter && category) letter = CATEGORY_MAP[category] || '';

                Store.books.push({
                  id: Store.genId(), num, title,
                  author:    authorIdx !== -1 ? (r[authorIdx]||'').toString().trim() : '',
                  category, letter,
                  publisher: publisherIdx !== -1 ? (r[publisherIdx]||'').toString().trim() : '',
                  year:      yearIdx !== -1 ? (r[yearIdx]||'').toString().trim() : '',
                  copies:    copiesIdx !== -1 ? (parseInt(r[copiesIdx])||1) : 1,
                  available: availIdx !== -1 && r[availIdx] !== undefined && r[availIdx] !== ''
                    ? (parseInt(r[availIdx]) >= 0 ? parseInt(r[availIdx]) : (copiesIdx !== -1 ? parseInt(r[copiesIdx])||1 : 1))
                    : (copiesIdx !== -1 ? parseInt(r[copiesIdx])||1 : 1),
                  addedAt: new Date().toISOString()
                });
                added++;
              }

              Store.save();
              Store.rebuildCategoryMaps();
              if (typeof Settings !== 'undefined') Settings.renderCategories();
              Books.buildCategoryDropdowns();
              Books.buildFilters();
              Toast.success(`تم استيراد ${added} كتاب بنجاح (تم تجاوز ${skipped} مكرر)`);
              if (UI.currentPage === 'books') Books.render();
              Dashboard.render();
            } catch(err) { console.error(err); Toast.error('خطأ أثناء الاستيراد'); }
            Loader.hide();
          }, 300);
        };

      } catch(err) { console.error(err); Toast.error('خطأ في قراءة ملف Excel'); Loader.hide(); }
    };
    reader.readAsArrayBuffer(file);
    e.target.value = '';
  },

  exportBooksCSV() {
    Loader.show('جاري إنشاء CSV...');
    setTimeout(() => {
      try {
        const header = ['رقم الكتاب','اسم الكتاب','المؤلف','التصنيف','عدد النسخ','الرقم الخاص','دار النشر','سنة النشر','المتاح'];
        const rows   = Store.books.map(b => [b.num,b.title,b.author,b.category,b.copies,b.letter||'',b.publisher||'',b.year||'',b.available]);
        const csv    = '\uFEFF' + [header, ...rows].map(r => r.map(c => `"${(c||'').toString().replace(/"/g,'""')}"`).join(',')).join('\n');
        download(csv, `كتب_المكتبة_${dateStamp()}.csv`, 'text/csv;charset=utf-8');
        Toast.success('تم تصدير CSV');
      } catch { Toast.error('خطأ أثناء التصدير'); }
      Loader.hide();
    }, 300);
  },

  importCSV(e) {
    const file = e.target.files[0]; if (!file) return;
    Loader.show('جاري قراءة CSV...');
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const text = ev.target.result.replace(/^\uFEFF/,'');
        const parseCSV = (str) => {
          const arr = [];
          let quote = false;
          let row = [''];
          for (let i = 0; i < str.length; i++) {
            let c = str[i];
            let next = str[i+1];
            if (c === '"') {
              if (quote && next === '"') { row[row.length - 1] += c; i++; }
              else { quote = !quote; }
            } else if (c === ',' && !quote) {
              row.push('');
            } else if ((c === '\r' || c === '\n') && !quote) {
              if (c === '\r' && next === '\n') { i++; }
              arr.push(row);
              row = [''];
            } else {
              row[row.length - 1] += c;
            }
          }
          if (row.length > 1 || row[0] !== '') { arr.push(row); }
          return arr;
        };
        const rows = parseCSV(text);
        if (rows.length < 2) { Toast.error('الملف فارغ'); Loader.hide(); return; }

        let added=0, skipped=0;
        
        const normalizeArabic = (str) => {
          if (!str) return '';
          return str.toString().trim().toLowerCase()
            .replace(/[\s\-_]+/g, '')
            .replace(/[أإآٱ]/g, 'ا')
            .replace(/ة/g, 'ه')
            .replace(/ى/g, 'ي')
            .replace(/[\u064B-\u065F]/g, '');
        };

        // Dynamically find the header row by searching the first 10 rows for matches with known book fields
        let headerRowIdx = 0;
        let maxMatches = 0;
        const keywords = ['اسم الكتاب', 'العنوان', 'عنوان الكتاب', 'الكتاب', 'الاسم', 'المؤلف', 'كاتب', 'اسم المؤلف', 'اسم الكاتب', 'التصنيف', 'القسم', 'نوع', 'الرقم الخاص', 'رقم خاص', 'الخاص', 'رقم مميز', 'الحرف المميز', 'الرمز المميز', 'الحرف', 'الرمز', 'الاختصار', 'كود الخاص', 'رقم الكتاب', 'الكود', 'كود الكتاب', 'الرقم العام', 'رقم عام', 'عدد النسخ', 'النسخ', 'العدد', 'المتاح', 'النسخ المتاحة'].map(k => normalizeArabic(k));

        for (let idx = 0; idx < Math.min(rows.length, 10); idx++) {
          const r = rows[idx];
          if (!r || !r.length) continue;
          const tempHeaders = r.map(h => normalizeArabic(h));
          let matches = 0;
          tempHeaders.forEach(h => {
            if (keywords.some(k => h.includes(k) || k.includes(h))) {
              matches++;
            }
          });
          if (matches > maxMatches) {
            maxMatches = matches;
            headerRowIdx = idx;
          }
        }
        
        const headers = rows[headerRowIdx].map(h => h.trim());
        const findColIdx = (prefixes) => {
          const normalizedPrefixes = prefixes.map(p => normalizeArabic(p));
          // 1. Try exact match first
          let idx = headers.findIndex(h => {
            const normalizedH = normalizeArabic(h);
            return normalizedPrefixes.some(p => normalizedH === p);
          });
          if (idx !== -1) return idx;
          
          // 2. Try substring match (header contains prefix)
          return headers.findIndex(h => {
            const normalizedH = normalizeArabic(h);
            return normalizedPrefixes.some(p => normalizedH.includes(p));
          });
        };

        const numIdx = findColIdx(['رقم الكتاب', 'الكود', 'كود الكتاب', 'الرقم العام', 'رقم عام']);
        const titleIdx = findColIdx(['اسم الكتاب', 'العنوان', 'عنوان الكتاب', 'اسم كتاب', 'الكتاب', 'الاسم']);
        const authorIdx = findColIdx(['المؤلف', 'كاتب', 'اسم المؤلف', 'اسم الكاتب']);
        const categoryIdx = findColIdx(['التصنيف', 'القسم', 'نوع']);
        const letterIdx = findColIdx(['الرقم الخاص', 'رقم خاص', 'الخاص', 'رقم مميز', 'رمز مميز', 'الحرف المميز', 'الرمز', 'الحرف', 'كود الخاص']);
        const publisherIdx = findColIdx(['دار النشر', 'الناشر', 'المطبعة']);
        const yearIdx = findColIdx(['سنة النشر', 'السنة', 'سنة']);
        const copiesIdx = findColIdx(['عدد النسخ', 'النسخ', 'العدد']);
        const availIdx = findColIdx(['المتاح', 'النسخ المتاحة']);

        if (titleIdx === -1) { 
          Toast.error('لم يتم العثور على عامود "اسم الكتاب" في ملف CSV. الأعمدة المتاحة: ' + headers.filter(Boolean).join(', ')); 
          Loader.hide(); 
          return; 
        }

        const extractPrefix = (str) => {
          if (!str) return '';
          const match = str.trim().match(/^([A-Za-z\u0621-\u064A]+)/);
          return match ? match[1].toUpperCase() : str.toUpperCase();
        };

        for (let i = headerRowIdx + 1; i < rows.length; i++) {
          const r = rows[i];
          if (!r || r.length < 2) continue;
          
          const title = (r[titleIdx]||'').trim();
          if (!title) { skipped++; continue; }

          let num = numIdx !== -1 ? (r[numIdx]||'').trim() : '';
          if (!num) {
            let max = 0;
            Store.books.forEach(b => {
              const val = parseInt(b.num, 10);
              if (!isNaN(val) && val > max) max = val;
            });
            num = String(Math.max(max, Store.books.length) + added + 1);
          }

          const dup = Store.books.find(b => b.num.toLowerCase() === num.toLowerCase() || b.title.toLowerCase() === title.toLowerCase());
          if (dup) { skipped++; continue; }

          const category = categoryIdx !== -1 ? (r[categoryIdx]||'').trim() : '';
          let letter = letterIdx !== -1 ? (r[letterIdx]||'').trim() : '';

          if (category) {
            const prefix = extractPrefix(letter) || category.substring(0, 2).toUpperCase();
            
            // Check if the category exists
            const existingCat = Store.categories.find(c => c.name.toLowerCase() === category.toLowerCase());
            if (existingCat) {
              if (prefix && existingCat.letter.toUpperCase() !== prefix) {
                existingCat.letter = prefix;
                Store.rebuildCategoryMaps();
              }
            } else {
              Store.categories.push({ name: category, letter: prefix });
              Store.rebuildCategoryMaps();
            }
          }

          if (!letter && category) {
            letter = CATEGORY_MAP[category] || '';
          }

          Store.books.push({
            id: Store.genId(),
            num, title,
            author: authorIdx !== -1 ? (r[authorIdx]||'').trim() : '',
            category,
            letter,
            publisher: publisherIdx !== -1 ? (r[publisherIdx]||'').trim() : '',
            year: yearIdx !== -1 ? (r[yearIdx]||'').trim() : '',
            copies: copiesIdx !== -1 ? (parseInt(r[copiesIdx])||1) : 1,
            available: availIdx !== -1 && r[availIdx] !== undefined && r[availIdx] !== '' ? (parseInt(r[availIdx]) >= 0 ? parseInt(r[availIdx]) : (copiesIdx !== -1 ? parseInt(r[copiesIdx])||1 : 1)) : (copiesIdx !== -1 ? parseInt(r[copiesIdx])||1 : 1),
            addedAt: new Date().toISOString()
          });
          added++;
        }
        
        Store.save();
        Store.rebuildCategoryMaps();
        if (typeof Settings !== 'undefined') Settings.renderCategories();
        Books.buildCategoryDropdowns();
        Books.buildFilters();

        Toast.success(`تم استيراد ${added} كتاب (تم تجاوز ${skipped} مكرر)`);
        if (UI.currentPage === 'books') Books.render();
        Dashboard.render();
      } catch { Toast.error('خطأ في قراءة ملف CSV'); }
      Loader.hide();
    };
    reader.readAsText(file, 'UTF-8');
    e.target.value = '';
  },

  showInfo() {
    const s    = Store.stats();
    const dataToMeasure = { books: Store.books, loans: Store.loans, borrowers: Store.borrowers, categories: Store.categories };
    const size = (JSON.stringify(dataToMeasure).length / 1024).toFixed(1);
    const el   = document.getElementById('backup-info-text');
    if (el) el.innerHTML = `كتب: <b>${s.totalBooks}</b> | استعارات: <b>${s.totalLoans}</b> | مستعيرون: <b>${Store.borrowers.length}</b><br>حجم البيانات: <b>${size} كيلوبايت</b>`;
  },

