  importExcel(e) {
    const file = e.target.files[0]; if (!file) return;
    if (!window.XLSX) { Toast.error('مكتبة Excel غير محملة'); return; }
    Loader.show('جاري قراءة الملف...');
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const wb   = XLSX.read(ev.target.result, { type: 'array' });
        const ws   = wb.Sheets[wb.SheetNames[0]];
        const rows = XLSX.utils.sheet_to_json(ws, { header: 1 });
        if (rows.length < 2) { Toast.error('الملف فارغ أو غير صالح'); Loader.hide(); return; }

        const normalizeArabic = (str) => {
          if (!str) return '';
          return str.toString().trim().toLowerCase()
            .replace(/[\s\-_]+/g, '')
            .replace(/[أإآٱ]/g, 'ا')
            .replace(/ة/g, 'ه')
            .replace(/ى/g, 'ي')
            .replace(/[\u064B-\u065F]/g, '');
        };

        // Dynamically find the header row
        let headerRowIdx = 0;
        let maxMatches = 0;
        const keywords = ['اسم الكتاب','العنوان','عنوان الكتاب','الكتاب','الاسم','المؤلف','كاتب','اسم المؤلف','اسم الكاتب','التصنيف','القسم','نوع','الرقم الخاص','رقم خاص','رقم مميز','الحرف المميز','الحرف','رقم الكتاب','الكود','الرقم العام','رقم عام','عدد النسخ','النسخ','العدد','المتاح','النسخ المتاحة'].map(k => normalizeArabic(k));
        for (let idx = 0; idx < Math.min(rows.length, 10); idx++) {
          const r = rows[idx];
          if (!r || !r.length) continue;
          const tempHeaders = r.map(h => normalizeArabic(h));
          let matches = 0;
          tempHeaders.forEach(h => { if (keywords.some(k => h.includes(k) || k.includes(h))) matches++; });
          if (matches > maxMatches) { maxMatches = matches; headerRowIdx = idx; }
        }

        const headers = rows[headerRowIdx].map(h => (h || '').toString().trim());
        const findColIdx = (prefixes) => {
          const np = prefixes.map(p => normalizeArabic(p));
          let idx = headers.findIndex(h => { const n = normalizeArabic(h); return np.some(p => n === p); });
          if (idx !== -1) return idx;
          return headers.findIndex(h => { const n = normalizeArabic(h); return np.some(p => n.includes(p)); });
        };

        const numIdx      = findColIdx(['رقم الكتاب','الكود','كود الكتاب','الرقم العام','رقم عام','رقم']);
        const titleIdx    = findColIdx(['اسم الكتاب','العنوان','عنوان الكتاب','اسم كتاب','الكتاب','الاسم','عنوان']);
        const authorIdx   = findColIdx(['المؤلف','كاتب','اسم المؤلف','اسم الكاتب']);
        const categoryIdx = findColIdx(['التصنيف','القسم','نوع']);
        const letterIdx   = findColIdx(['الرقم الخاص','رقم خاص','رقم مميز','رمز مميز','الحرف المميز','الحرف','كود الخاص']);
        const publisherIdx= findColIdx(['دار النشر','الناشر','المطبعة']);
        const yearIdx     = findColIdx(['سنة النشر','السنة','سنة']);
        const copiesIdx   = findColIdx(['عدد النسخ','النسخ','العدد']);
        const availIdx    = findColIdx(['المتاح','النسخ المتاحة']);

        if (titleIdx === -1) {
          Toast.error('لم يتم العثور على عامود "اسم الكتاب". الأعمدة الموجودة: ' + headers.filter(Boolean).join(', '));
          Loader.hide(); return;
        }

        // ── Build preview modal ──
        const colMap = [
          { label: 'رقم الكتاب',   idx: numIdx },
          { label: 'اسم الكتاب',   idx: titleIdx },
          { label: 'اسم الكاتب',   idx: authorIdx },
          { label: 'التصنيف',      idx: categoryIdx },
          { label: 'عدد النسخ',   idx: copiesIdx },
          { label: 'الرقم الخاص', idx: letterIdx },
        ];

        // Summary rows: which column name was mapped to what
        const mappingRows = colMap.map(c => `
          <tr>
            <td style="padding:6px 12px;font-weight:700;color:#4a6fa5">${c.label}</td>
            <td style="padding:6px 12px">
              ${c.idx !== -1
                ? `<span style="background:#e8f5e9;color:#2e7d32;padding:3px 10px;border-radius:6px;font-weight:600">✓ ${headers[c.idx] || '(عامود '+c.idx+')'}</span>`
                : `<span style="background:#fde8e8;color:#c62828;padding:3px 10px;border-radius:6px">✗ غير موجود</span>`}
            </td>
          </tr>`).join('');

        // Data preview: first 8 data rows
        const previewRows = rows.slice(headerRowIdx + 1, headerRowIdx + 9)
          .filter(r => r && r.length && (titleIdx === -1 || (r[titleIdx]||'').toString().trim()))
          .map(r => `<tr>
            ${colMap.map(c => `<td style="padding:5px 10px;border-bottom:1px solid #eee;white-space:nowrap;max-width:180px;overflow:hidden;text-overflow:ellipsis" title="${c.idx !== -1 ? (r[c.idx]||'') : '—'}">${c.idx !== -1 ? (r[c.idx]||'—') : '—'}</td>`).join('')}
          </tr>`).join('');

        const previewHeader = colMap.map(c => `<th style="padding:8px 10px;background:#4a6fa5;color:#fff;white-space:nowrap">${c.label}</th>`).join('');

        const totalDataRows = rows.slice(headerRowIdx + 1).filter(r => r && r.length && (titleIdx === -1 || (r[titleIdx]||'').toString().trim())).length;

        // Remove existing preview modal if any
        document.getElementById('excel-preview-modal')?.remove();

        const modal = document.createElement('div');
        modal.id = 'excel-preview-modal';
        modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;display:flex;align-items:center;justify-content:center;padding:16px;direction:rtl';
        modal.innerHTML = `
          <div style="background:#fff;border-radius:16px;width:100%;max-width:780px;max-height:90vh;overflow:auto;box-shadow:0 20px 60px rgba(0,0,0,.4);font-family:Cairo,sans-serif">
            <div style="background:linear-gradient(135deg,#4a6fa5,#2196f3);color:#fff;padding:20px 24px;border-radius:16px 16px 0 0;display:flex;align-items:center;gap:12px">
              <i class="fas fa-table" style="font-size:22px"></i>
              <div>
