      } catch(e) { Toast.error('خطأ أثناء التصدير'); }
      Loader.hide();
    }, 400);
  },

  importJSON(e) {
    const file = e.target.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const data = JSON.parse(ev.target.result);
        if (!data.books && !data.loans && !data.borrowers) { Toast.error('ملف JSON غير صالح'); return; }
        
        // Calculate what needs to be imported
        const incomingBooks = data.books || [];
        const incomingLoans = data.loans || [];
        const incomingBorrowers = data.borrowers || [];
        const incomingCategories = data.categories || [];

        // 1. Books to add (not matching title or num)
        const booksToAdd = incomingBooks.filter(incomingB => {
          return !Store.books.some(existingB => 
            existingB.title.trim().toLowerCase() === incomingB.title.trim().toLowerCase() ||
            existingB.num.trim().toLowerCase() === incomingB.num.trim().toLowerCase()
          );
        });

        // 2. Borrowers to add (not matching name)
        const borrowersToAdd = incomingBorrowers.filter(incomingBr => {
          return !Store.borrowers.some(existingBr =>
            existingBr.name.trim().toLowerCase() === incomingBr.name.trim().toLowerCase()
          );
        });

        // 3. Categories to add (not matching name)
        const categoriesToAdd = incomingCategories.filter(incomingC => {
          return !Store.categories.some(existingC =>
            existingC.name.trim().toLowerCase() === incomingC.name.trim().toLowerCase()
          );
        });

        // 4. Loans to add (not matching by borrowerName, bookTitle and loanDate)
        const loansToAdd = incomingLoans.filter(incomingL => {
          return !Store.loans.some(existingL =>
            existingL.borrowerName.trim().toLowerCase() === incomingL.borrowerName.trim().toLowerCase() &&
            existingL.bookTitle.trim().toLowerCase() === incomingL.bookTitle.trim().toLowerCase() &&
            existingL.loanDate === incomingL.loanDate
          );
        });

        const totalToAdd = booksToAdd.length + borrowersToAdd.length + loansToAdd.length + categoriesToAdd.length;

        if (totalToAdd === 0) {
          Toast.info('جميع البيانات الموجودة في الملف مسجلة بالفعل بالبرنامج ولا توجد عناصر جديدة لإضافتها.');
          return;
        }

        Modal.confirm(`
          <strong>دمج البيانات الذكي</strong><br><br>
          تم العثور على عناصر جديدة سيتم إضافتها:<br>
          الكتب الجديدة: <strong>${booksToAdd.length}</strong> (من أصل ${incomingBooks.length})<br>
          المستعيرون الجدد: <strong>${borrowersToAdd.length}</strong> (من أصل ${incomingBorrowers.length})<br>
          سجلات الاستعارة الجديدة: <strong>${loansToAdd.length}</strong> (من أصل ${incomingLoans.length})<br>
          تصنيفات جديدة: <strong>${categoriesToAdd.length}</strong> (من أصل ${incomingCategories.length})<br><br>
          هل تريد الاستمرار ودمج هذه العناصر فقط؟`, () => {
          Loader.show('جاري دمج البيانات...');
          setTimeout(() => {
            // Append missing items
            Store.books = [...Store.books, ...booksToAdd];
            Store.loans = [...Store.loans, ...loansToAdd];
            Store.borrowers = [...Store.borrowers, ...borrowersToAdd];
            
            if (categoriesToAdd.length > 0) {
              Store.categories = [...Store.categories, ...categoriesToAdd];
              Storage.set('clib_custom_categories', Store.categories);
              Store.rebuildCategoryMaps();
              Books.buildCategoryDropdowns();
            }

            Store.save();
            Store.updateLoanStatuses();
            Toast.success(`تم دمج البيانات بنجاح! (أضيف ${booksToAdd.length} كتاب، ${borrowersToAdd.length} مستعير، ${loansToAdd.length} استعارة)`);
            UI.navigate('dashboard');
            Dashboard.render();
            Loader.hide();
          }, 500);
        });
      } catch (err) { 
        console.error(err);
        Toast.error('خطأ في قراءة ملف الباك أب. تأكد أنه ملف JSON صحيح.'); 
      }
    };
    reader.readAsText(file);
    e.target.value = '';
  },

