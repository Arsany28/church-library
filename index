<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="نظام إدارة مكتبة الكنيسة - إدارة احترافية للكتب والاستعارة والمستعيرين">
<title>مكتبة كنيسة مارجرجس بدسوق - نظام الإدارة</title>

<!-- Google Fonts - Cairo -->
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<!-- SheetJS for Excel support -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<style>
/* ============================================================
   ROOT VARIABLES & RESET
============================================================ */
:root {
  --primary: #4a6fa5;
  --primary-dark: #3a5a8a;
  --primary-light: #6b8fc7;
  --secondary: #7c9bb5;
  --accent: #e8a838;
  --accent-dark: #c98a20;
  --success: #3da06a;
  --danger: #d64545;
  --warning: #e8a838;
  --info: #4a7fb5;

  --bg: #f0f4f8;
  --bg2: #e8edf2;
  --surface: #ffffff;
  --surface2: #f7f9fc;
  --border: #d0dbe8;
  --border2: #b8c8d8;

  --text: #1a2840;
  --text2: #3a4d65;
  --text3: #6a7d95;
  --text-inv: #ffffff;

  --sidebar-w: 260px;
  --header-h: 64px;
  --radius: 12px;
  --radius-sm: 8px;
  --shadow: 0 2px 12px rgba(74,111,165,0.10);
  --shadow-lg: 0 8px 32px rgba(74,111,165,0.15);
  --transition: 0.25s ease;
  --font: 'Cairo', 'Segoe UI', sans-serif;
}

[data-theme="dark"] {
  --bg: #0f1a2e;
  --bg2: #162035;
  --surface: #1e2d45;
  --surface2: #243350;
  --border: #2e4060;
  --border2: #3d5278;
  --text: #e8f0fa;
  --text2: #b8c8de;
  --text3: #7a94b0;
  --shadow: 0 2px 12px rgba(0,0,0,0.35);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.45);
}

[data-accent="teal"]    { --primary:#2a8a7a; --primary-dark:#1e6e61; --primary-light:#3cb8a5; }
[data-accent="purple"]  { --primary:#6a4fa5; --primary-dark:#553d8a; --primary-light:#8b6fc7; }
[data-accent="rose"]    { --primary:#a5405a; --primary-dark:#8a3048; --primary-light:#c76080; }
[data-accent="olive"]   { --primary:#6a7a35; --primary-dark:#556228; --primary-light:#8b9f50; }

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { font-size: 16px; scroll-behavior: smooth; }
body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  direction: rtl;
  transition: background var(--transition), color var(--transition);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ============================================================
   SCROLLBAR
============================================================ */
::-webkit-scrollbar { width: 7px; height: 7px; }
::-webkit-scrollbar-track { background: var(--bg2); }
::-webkit-scrollbar-thumb { background: var(--primary-light); border-radius: 8px; }

/* ============================================================
   LAYOUT
============================================================ */
#app { display: flex; min-height: 100vh; }

/* SIDEBAR */
#sidebar {
  width: var(--sidebar-w);
  background: linear-gradient(175deg, var(--primary-dark) 0%, var(--primary) 60%, var(--primary-light) 100%);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; right: 0; bottom: 0;
  z-index: 200;
  transition: transform var(--transition), width var(--transition);
  box-shadow: -4px 0 24px rgba(0,0,0,0.18);
}

#sidebar.collapsed { transform: translateX(100%); }

.sidebar-logo {
  padding: 24px 20px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  gap: 12px;
}
.sidebar-logo .logo-icon {
  width: 44px; height: 44px;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem; color: #fff;
  flex-shrink: 0;
}
.sidebar-logo .logo-text { color: #fff; }
.sidebar-logo .logo-text h2 { font-size: 1rem; font-weight: 700; line-height: 1.2; }
.sidebar-logo .logo-text p { font-size: 0.72rem; opacity: 0.75; }

.sidebar-nav { flex: 1; padding: 12px 0; overflow-y: auto; }

.nav-group-label {
  font-size: 0.68rem;
  font-weight: 700;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0.08em;
  padding: 14px 20px 6px;
  text-transform: uppercase;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 20px;
  color: rgba(255,255,255,0.82);
  cursor: pointer;
  border-right: 3px solid transparent;
  transition: all var(--transition);
  font-size: 0.92rem;
  font-weight: 500;
  position: relative;
}
.nav-item:hover { background: rgba(255,255,255,0.10); color: #fff; border-right-color: rgba(255,255,255,0.4); }
.nav-item.active { background: rgba(255,255,255,0.18); color: #fff; border-right-color: #fff; font-weight: 700; }
.nav-item .nav-icon { width: 22px; text-align: center; font-size: 1rem; }
.nav-item .nav-badge {
  margin-right: auto;
  background: var(--accent);
  color: #fff;
  border-radius: 20px;
  padding: 1px 8px;
  font-size: 0.7rem;
  font-weight: 700;
}

.sidebar-footer {
  padding: 12px 20px;
  border-top: 1px solid rgba(255,255,255,0.15);
  font-size: 0.75rem;
  color: rgba(255,255,255,0.5);
  text-align: center;
}

/* MAIN CONTENT */
#main {
  flex: 1;
  margin-right: var(--sidebar-w);
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  transition: margin-right var(--transition);
  min-width: 0;
  width: 0;
}
#main.expanded { margin-right: 0; }

/* HEADER */
#header {
  height: var(--header-h);
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 24px;
  gap: 16px;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: var(--shadow);
}
#header .menu-btn {
  background: none; border: none;
  color: var(--text3); cursor: pointer;
  font-size: 1.2rem; padding: 6px;
  border-radius: var(--radius-sm);
  transition: all var(--transition);
}
#header .menu-btn:hover { color: var(--primary); background: var(--bg2); }

#page-title {
  font-size: 1.15rem; font-weight: 700;
  color: var(--text); flex: 1;
}

#header .header-actions { display: flex; align-items: center; gap: 10px; }
.header-btn {
  background: none; border: none; cursor: pointer;
  color: var(--text3); font-size: 1.05rem;
  padding: 7px 10px; border-radius: var(--radius-sm);
  transition: all var(--transition); position: relative;
}
.header-btn:hover { color: var(--primary); background: var(--bg2); }
.header-btn .badge {
  position: absolute; top: 2px; left: 2px;
  background: var(--danger); color: #fff;
  border-radius: 50%; width: 16px; height: 16px;
  font-size: 0.6rem; display: flex; align-items: center; justify-content: center;
  font-weight: 700;
}

/* CONTENT AREA */
#content {
  flex: 1;
  padding: 24px;
  overflow-y: auto;
  overflow-x: hidden;
  min-width: 0;
}

/* ============================================================
   PAGES
============================================================ */
.page { display: none; animation: fadeIn 0.3s ease; }
.page.active { display: block; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

/* ============================================================
   STATS CARDS
============================================================ */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 16px;
  margin-bottom: 28px;
}

.stat-card {
  background: var(--surface);
  border-radius: var(--radius);
  padding: 20px 18px;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 14px;
  transition: all var(--transition);
  cursor: default;
  position: relative;
  overflow: hidden;
}
.stat-card::before {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 4px; height: 100%;
  background: var(--card-color, var(--primary));
  border-radius: 0 var(--radius) var(--radius) 0;
}
.stat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
.stat-icon {
  width: 48px; height: 48px;
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.3rem; color: #fff;
  flex-shrink: 0;
  background: var(--card-color, var(--primary));
}
.stat-body .stat-value { font-size: 1.6rem; font-weight: 800; line-height: 1; color: var(--text); }
.stat-body .stat-label { font-size: 0.78rem; color: var(--text3); margin-top: 4px; font-weight: 500; }

/* ============================================================
   CARDS / PANELS
============================================================ */
.panel {
  background: var(--surface);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
  overflow: visible;
  margin-bottom: 20px;
  min-width: 0;
}
.panel-header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  background: var(--surface2);
}
.panel-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 8px;
}
.panel-title i { color: var(--primary); }
.panel-body { padding: 20px; }
.panel-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }

/* ============================================================
   BUTTONS
============================================================ */
.btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 9px 18px;
  border-radius: var(--radius-sm);
  border: none; cursor: pointer;
  font-family: var(--font); font-size: 0.88rem; font-weight: 600;
  transition: all var(--transition); white-space: nowrap;
}
.btn-sm { padding: 6px 12px; font-size: 0.8rem; }
.btn-xs { padding: 4px 9px; font-size: 0.75rem; }
.btn-lg { padding: 12px 24px; font-size: 1rem; }
.btn-block { width: 100%; justify-content: center; }

.btn-primary { background: var(--primary); color: #fff; }
.btn-primary:hover { background: var(--primary-dark); transform: translateY(-1px); }
.btn-secondary { background: var(--bg2); color: var(--text2); border: 1px solid var(--border); }
.btn-secondary:hover { background: var(--border); }
.btn-success { background: var(--success); color: #fff; }
.btn-success:hover { background: #2d8a58; }
.btn-danger { background: var(--danger); color: #fff; }
.btn-danger:hover { background: #b83535; }
.btn-warning { background: var(--warning); color: #fff; }
.btn-warning:hover { background: var(--accent-dark); }
.btn-info { background: var(--info); color: #fff; }
.btn-info:hover { background: #3a6a9a; }
.btn-outline { background: transparent; color: var(--primary); border: 2px solid var(--primary); }
.btn-outline:hover { background: var(--primary); color: #fff; }
.btn-icon { padding: 8px; border-radius: var(--radius-sm); background: var(--bg2); border: 1px solid var(--border); color: var(--text3); }
.btn-icon:hover { color: var(--primary); border-color: var(--primary); }

/* ============================================================
   FORMS
============================================================ */
.form-group { margin-bottom: 16px; }
.form-label {
  display: block; font-size: 0.85rem; font-weight: 600;
  color: var(--text2); margin-bottom: 6px;
}
.form-label.required::after { content: ' *'; color: var(--danger); }
.form-control {
  width: 100%; padding: 10px 14px;
  border: 1.5px solid var(--border2);
  border-radius: var(--radius-sm);
  background: var(--surface);
  color: var(--text);
  font-family: var(--font); font-size: 0.9rem;
  transition: all var(--transition);
  outline: none;
}
.form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(74,111,165,0.12); }
.form-control.error { border-color: var(--danger); }
.form-control::placeholder { color: var(--text3); }
.form-control:disabled { background: var(--bg2); opacity: 0.7; cursor: not-allowed; }

select.form-control { cursor: pointer; }
textarea.form-control { resize: vertical; min-height: 80px; }

.form-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0 16px; }
.form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0 16px; }
.form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0 16px; }
.span-2 { grid-column: span 2; }
.span-3 { grid-column: span 3; }

.input-group { display: flex; gap: 0; }
.input-group .form-control { border-radius: var(--radius-sm) 0 0 var(--radius-sm); }
.input-group .btn { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }

.form-error { color: var(--danger); font-size: 0.78rem; margin-top: 4px; display: none; font-weight: 600; animation: shakeError 0.3s ease; }
.form-error.show { display: flex; align-items: center; gap: 5px; }
.form-error i { font-size: 0.72rem; }
@keyframes shakeError { 0%,100%{transform:translateX(0)} 25%{transform:translateX(4px)} 75%{transform:translateX(-4px)} }

/* Autocomplete */
.autocomplete-wrapper { position: relative; }
.autocomplete-list {
  position: absolute; top: 100%; right: 0; left: 0;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  max-height: 200px; overflow-y: auto;
  z-index: 500; box-shadow: var(--shadow-lg);
  display: none;
}
.autocomplete-list.show { display: block; }
.autocomplete-item {
  padding: 10px 14px; cursor: pointer;
  font-size: 0.87rem; transition: background var(--transition);
}
.autocomplete-item:hover, .autocomplete-item.selected { background: var(--bg2); color: var(--primary); }

/* ============================================================
   TABLE
============================================================ */
.table-wrapper {
  display: block;
  width: 100%;
  max-width: 100%;
  overflow-x: auto !important;
  -webkit-overflow-scrolling: touch;
  position: relative;
  border-radius: var(--radius);
  border: 1px solid var(--border);
  scrollbar-width: auto;
  scrollbar-color: var(--primary) var(--surface2);
}
.table-wrapper::-webkit-scrollbar { height: 10px; display: block !important; }
.table-wrapper::-webkit-scrollbar-track { background: var(--surface2); border-radius: 4px; }
.table-wrapper::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 4px; min-width: 40px; }
.table-wrapper::-webkit-scrollbar-thumb:hover { background: var(--primary-dark); }
.table-scroll-hint {
  display: none; position: absolute; top: 0; left: 0; width: 40px; height: 100%;
  background: linear-gradient(to right, rgba(0,0,0,0.08), transparent);
  pointer-events: none; z-index: 2; border-radius: var(--radius) 0 0 var(--radius);
}
.table-scroll-hint.right { left: auto; right: 0; background: linear-gradient(to left, rgba(0,0,0,0.08), transparent); border-radius: 0 var(--radius) var(--radius) 0; }
.table-scroll-hint.visible { display: block; }
.data-table {
  width: 100%; border-collapse: collapse;
  font-size: 0.87rem; white-space: nowrap;
}
.data-table th {
  background: var(--surface2);
  color: var(--text2); font-weight: 700;
  padding: 12px 14px;
  border-bottom: 2px solid var(--border);
  text-align: right; cursor: pointer;
  user-select: none; transition: background var(--transition);
  white-space: nowrap;
}
.data-table th:hover { background: var(--bg2); }
.data-table th.sort-asc::after  { content: ' ▲'; color: var(--primary); font-size: 0.7rem; }
.data-table th.sort-desc::after { content: ' ▼'; color: var(--primary); font-size: 0.7rem; }
.data-table td {
  padding: 11px 14px;
  border-bottom: 1px solid var(--border);
  color: var(--text);
  vertical-align: middle;
}
.data-table tr:hover td { background: var(--bg2); }
.data-table tr.overdue td { background: rgba(214,69,69,0.06); }
.data-table tr.overdue td:first-child { border-right: 3px solid var(--danger); }

.badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 10px; border-radius: 20px;
  font-size: 0.75rem; font-weight: 700;
}
.badge-success { background: rgba(61,160,106,0.15); color: var(--success); }
.badge-danger  { background: rgba(214,69,69,0.15); color: var(--danger); }
.badge-warning { background: rgba(232,168,56,0.15); color: var(--warning); }
.badge-info    { background: rgba(74,127,181,0.15); color: var(--info); }
.badge-secondary { background: var(--bg2); color: var(--text3); }

.table-actions { display: flex; gap: 5px; justify-content: center; }

/* ============================================================
   SEARCH BAR
============================================================ */
.search-bar {
  display: flex; gap: 10px; align-items: center;
  flex-wrap: wrap; margin-bottom: 16px;
}
.search-input-wrapper {
  position: relative; flex: 1; min-width: 200px;
}
.search-input-wrapper i {
  position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
  color: var(--text3);
}
.search-input-wrapper .form-control { padding-right: 38px; }
.results-count { font-size: 0.82rem; color: var(--text3); white-space: nowrap; align-self: center; }

/* ============================================================
   PAGINATION
============================================================ */
.pagination {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 20px;
  border-top: 1px solid var(--border);
  flex-wrap: wrap; gap: 10px;
}
.page-info { font-size: 0.82rem; color: var(--text3); }
.page-controls { display: flex; gap: 5px; align-items: center; }
.page-btn {
  min-width: 34px; height: 34px;
  border: 1px solid var(--border);
  background: var(--surface);
  border-radius: var(--radius-sm);
  cursor: pointer; font-size: 0.85rem;
  color: var(--text2); transition: all var(--transition);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font);
}
.page-btn:hover { border-color: var(--primary); color: var(--primary); }
.page-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); font-weight: 700; }
.page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.page-size-select { padding: 6px 10px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); color: var(--text); font-family: var(--font); font-size: 0.82rem; }

/* ============================================================
   MODAL
============================================================ */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 1000;
  display: flex; align-items: center; justify-content: center;
  padding: 16px;
  animation: fadeInOverlay 0.2s ease;
  backdrop-filter: blur(3px);
}
@keyframes fadeInOverlay { from { opacity: 0; } to { opacity: 1; } }
.modal {
  background: var(--surface);
  border-radius: var(--radius);
  width: 100%; max-width: 640px;
  max-height: 90vh;
  overflow: hidden; display: flex; flex-direction: column;
  box-shadow: 0 20px 60px rgba(0,0,0,0.35);
  animation: slideUp 0.25s ease;
}
.modal-lg { max-width: 860px; }
.modal-sm { max-width: 460px; }
@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
.modal-header {
  padding: 18px 22px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 12px;
  background: var(--surface2);
}
.modal-header h3 { flex: 1; font-size: 1.05rem; font-weight: 700; }
.modal-close {
  background: none; border: none; cursor: pointer;
  color: var(--text3); font-size: 1.1rem; padding: 5px;
  border-radius: var(--radius-sm); transition: all var(--transition);
}
.modal-close:hover { color: var(--danger); background: rgba(214,69,69,0.1); }
.modal-body { padding: 22px; overflow-y: auto; flex: 1; }
.modal-footer {
  padding: 14px 22px;
  border-top: 1px solid var(--border);
  display: flex; justify-content: flex-end; gap: 10px;
  background: var(--surface2);
}

/* ============================================================
   TOAST NOTIFICATIONS
============================================================ */
#toast-container {
  position: fixed; bottom: 24px; left: 24px;
  z-index: 9999;
  display: flex; flex-direction: column; gap: 10px;
}
.toast {
  background: var(--surface);
  border-radius: var(--radius-sm);
  padding: 14px 18px;
  box-shadow: var(--shadow-lg);
  border-right: 4px solid;
  display: flex; align-items: center; gap: 12px;
  min-width: 300px; max-width: 400px;
  animation: slideInToast 0.3s ease;
  font-size: 0.9rem; font-weight: 500;
  color: var(--text);
}
@keyframes slideInToast { from { transform: translateX(-20px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
.toast.hide { animation: slideOutToast 0.3s ease forwards; }
@keyframes slideOutToast { to { transform: translateX(-20px); opacity: 0; } }
.toast-success { border-right-color: var(--success); }
.toast-success .toast-icon { color: var(--success); }
.toast-danger  { border-right-color: var(--danger); }
.toast-danger  .toast-icon { color: var(--danger); }
.toast-warning { border-right-color: var(--warning); }
.toast-warning .toast-icon { color: var(--warning); }
.toast-info    { border-right-color: var(--info); }
.toast-info    .toast-icon { color: var(--info); }
.toast-icon { font-size: 1.15rem; flex-shrink: 0; }
.toast-msg { flex: 1; }
.toast-close { background: none; border: none; cursor: pointer; color: var(--text3); font-size: 0.9rem; padding: 0 4px; }

/* ============================================================
   LOADING SPINNER
============================================================ */
#loading-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 9998;
  display: none;
  align-items: center; justify-content: center;
  flex-direction: column; gap: 16px;
}
#loading-overlay.show { display: flex; }
.spinner {
  width: 52px; height: 52px;
  border: 5px solid rgba(255,255,255,0.2);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
#loading-overlay p { color: #fff; font-size: 0.95rem; font-weight: 600; }

/* ============================================================
   DETAIL VIEW
============================================================ */
.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.detail-item label { font-size: 0.78rem; color: var(--text3); font-weight: 600; display: block; margin-bottom: 3px; }
.detail-item p { font-size: 0.92rem; color: var(--text); font-weight: 500; }
.detail-item.full { grid-column: span 2; }

/* ============================================================
   BORROWER AUTOCOMPLETE
============================================================ */
.borrower-suggestions {
  position: absolute; top: 100%; right: 0; left: 0; z-index: 600;
  background: var(--surface); border: 1px solid var(--border);
  border-top: none; border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  box-shadow: var(--shadow-lg); max-height: 220px; overflow-y: auto; display: none;
}
.borrower-suggestions.show { display: block; }
.sug-item {
  padding: 10px 14px; cursor: pointer; border-bottom: 1px solid var(--border);
  transition: background var(--transition);
}
.sug-item:hover { background: var(--bg2); }
.sug-item .sug-name { font-weight: 600; font-size: 0.88rem; }
.sug-item .sug-phone { font-size: 0.78rem; color: var(--text3); }

/* ============================================================
   TABS
============================================================ */
.tabs { display: flex; border-bottom: 2px solid var(--border); gap: 4px; margin-bottom: 20px; flex-wrap: wrap; }
.tab-btn {
  padding: 10px 18px; background: none; border: none;
  cursor: pointer; font-family: var(--font); font-size: 0.88rem;
  font-weight: 600; color: var(--text3);
  border-bottom: 3px solid transparent; margin-bottom: -2px;
  transition: all var(--transition);
}
.tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); }
.tab-btn:hover:not(.active) { color: var(--text2); background: var(--bg2); }
.tab-content { display: none; }
.tab-content.active { display: block; animation: fadeIn 0.25s ease; }

/* ============================================================
   BACKUP CARDS
============================================================ */
.backup-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
.backup-card {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 22px;
  text-align: center;
  transition: all var(--transition);
}
.backup-card:hover { box-shadow: var(--shadow-lg); border-color: var(--primary); }
.backup-card .bc-icon {
  font-size: 2.2rem; margin-bottom: 12px;
  color: var(--primary);
}
.backup-card h4 { font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
.backup-card p { font-size: 0.82rem; color: var(--text3); margin-bottom: 14px; }

/* ============================================================
   SETTINGS
============================================================ */
.settings-section { margin-bottom: 28px; }
.settings-section h3 { font-size: 0.95rem; font-weight: 700; color: var(--primary); margin-bottom: 14px; padding-bottom: 8px; border-bottom: 2px solid var(--border); }
.settings-row { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border); gap: 16px; }
.settings-row:last-child { border-bottom: none; }
.settings-row label { font-size: 0.9rem; font-weight: 600; color: var(--text2); }
.settings-row p { font-size: 0.8rem; color: var(--text3); margin-top: 3px; }

/* Toggle Switch */
.toggle-switch { position: relative; width: 44px; height: 24px; flex-shrink: 0; }
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.toggle-slider {
  position: absolute; inset: 0; background: var(--border2);
  border-radius: 24px; cursor: pointer; transition: all 0.3s;
}
.toggle-slider::before {
  content: ''; position: absolute;
  width: 18px; height: 18px; border-radius: 50%;
  background: #fff; top: 3px; right: 3px;
  transition: all 0.3s;
  box-shadow: 0 1px 4px rgba(0,0,0,0.2);
}
input:checked + .toggle-slider { background: var(--primary); }
input:checked + .toggle-slider::before { transform: translateX(-20px); }

/* Color swatches */
.color-swatches { display: flex; gap: 8px; }
.swatch {
  width: 30px; height: 30px; border-radius: 50%;
  cursor: pointer; border: 3px solid transparent;
  transition: all var(--transition);
}
.swatch.active, .swatch:hover { border-color: var(--text); transform: scale(1.1); }

/* Font size */
.font-size-options { display: flex; gap: 6px; }
.font-size-btn {
  padding: 5px 12px; border: 1.5px solid var(--border);
  background: var(--surface); border-radius: var(--radius-sm);
  cursor: pointer; font-family: var(--font); color: var(--text2); font-weight: 600;
  transition: all var(--transition);
}
.font-size-btn.active, .font-size-btn:hover { border-color: var(--primary); color: var(--primary); background: rgba(74,111,165,0.08); }

/* Column toggles */
.column-toggles { display: flex; flex-wrap: wrap; gap: 10px; }
.col-toggle {
  display: flex; align-items: center; gap: 6px;
  padding: 7px 12px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  cursor: pointer; transition: all var(--transition);
  font-size: 0.83rem; font-weight: 600; color: var(--text3);
  background: var(--surface);
}
.col-toggle.active { border-color: var(--primary); color: var(--primary); background: rgba(74,111,165,0.08); }
.col-toggle i { font-size: 0.9rem; }

/* ============================================================
   KEYBOARD SHORTCUTS HELP
============================================================ */
.shortcuts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 24px; }
.shortcut-item { display: flex; align-items: center; gap: 10px; font-size: 0.85rem; }
.shortcut-item kbd {
  background: var(--bg2); border: 1px solid var(--border2);
  border-radius: 5px; padding: 3px 9px; font-size: 0.78rem;
  font-family: monospace; font-weight: 700; color: var(--text2);
  box-shadow: 0 2px 0 var(--border2); white-space: nowrap;
}

/* ============================================================
   EMPTY STATE
============================================================ */
.empty-state {
  text-align: center; padding: 60px 20px; color: var(--text3);
}
.empty-state i { font-size: 3.5rem; margin-bottom: 16px; display: block; opacity: 0.4; }
.empty-state p { font-size: 1rem; font-weight: 500; }

/* ============================================================
   PRINT STYLES
============================================================ */
@media print {
  #sidebar, #header, .panel-actions, .table-actions,
  .btn, .search-bar, .pagination, #toast-container,
  #loading-overlay, .modal-overlay, .no-print { display: none !important; }
  body { background: #fff; color: #000; font-size: 12pt; }
  #main { margin-right: 0 !important; }
  #content { padding: 0; }
  .panel { box-shadow: none; border: 1px solid #ccc; }
  .data-table th, .data-table td { border: 1px solid #ccc; }
  .print-header { display: block !important; text-align: center; margin-bottom: 20px; }
  .print-header h1 { font-size: 18pt; }
  .print-header p { font-size: 11pt; color: #555; }
}
.print-header { display: none; }

/* ============================================================
   RESPONSIVE
============================================================ */
@media (max-width: 768px) {
  :root { --sidebar-w: 0px; }
  #sidebar { width: 260px; transform: translateX(100%); }
  #sidebar.mobile-open { transform: translateX(0); }
  #main { margin-right: 0; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .form-grid-3 { grid-template-columns: 1fr; }
  .form-grid-2 { grid-template-columns: 1fr; }
  .span-2, .span-3 { grid-column: span 1; }
  #content { padding: 14px; }
  .detail-grid { grid-template-columns: 1fr; }
  .detail-item.full { grid-column: span 1; }
  .shortcuts-grid { grid-template-columns: 1fr; }
}

@media (max-width: 480px) {
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .stat-card { padding: 14px 12px; }
  .stat-icon { width: 38px; height: 38px; font-size: 1.1rem; }
  .stat-body .stat-value { font-size: 1.3rem; }
}

/* ============================================================
   FONT SIZE CLASSES
============================================================ */
.font-sm { font-size: 14px !important; }
.font-md { font-size: 16px !important; }
.font-lg { font-size: 18px !important; }

/* ============================================================
   DRAG HANDLE
============================================================ */
.drag-handle { cursor: grab; color: var(--text3); font-size: 0.9rem; }
.drag-handle:active { cursor: grabbing; }

/* ============================================================
   MISC
============================================================ */
.text-success { color: var(--success); }
.text-danger  { color: var(--danger); }
.text-warning { color: var(--warning); }
.text-muted   { color: var(--text3); }
.text-center  { text-align: center; }
.fw-bold { font-weight: 700; }
.mb-0 { margin-bottom: 0; }
.mt-3 { margin-top: 12px; }
.d-flex { display: flex; }
.align-center { align-items: center; }
.gap-2 { gap: 8px; }
.gap-3 { gap: 12px; }
.w-100 { width: 100%; }

/* Overlay for mobile sidebar */
.sidebar-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.4); z-index: 190;
}
.sidebar-overlay.show { display: block; }

/* Confirm Dialog */
.confirm-msg { font-size: 0.95rem; line-height: 1.7; color: var(--text2); text-align: center; }
.confirm-msg strong { color: var(--danger); }
</style>
</head>
