const Backup = {
  exportJSON() {
    Loader.show('جاري إعداد الملف...');
    setTimeout(() => {
      try {
        const data = { books: Store.books, loans: Store.loans, borrowers: Store.borrowers, categories: Store.categories, exportedAt: new Date().toISOString(), version: '1.0' };
        download(JSON.stringify(data, null, 2), `مكتبة_الكنيسة_${dateStamp()}.json`, 'application/json');
