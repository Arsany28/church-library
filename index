/* ============================================================
   MODAL MANAGER
============================================================ */
const Modal = {
  _stack: [],

  show({ title, body, footer = '', size = '', id = null }) {
    const modalId = id || 'modal-' + Date.now();
    const html = `
      <div class="modal-overlay" id="${modalId}" onclick="Modal._overlayClick(event,'${modalId}')">
        <div class="modal ${size ? 'modal-' + size : ''}">
          <div class="modal-header">
            <h3>${title}</h3>
            <button class="modal-close" onclick="Modal.close('${modalId}')"><i class="fas fa-times"></i></button>
          </div>
          <div class="modal-body">${body}</div>
          ${footer ? `<div class="modal-footer">${footer}</div>` : ''}
        </div>
      </div>`;
    document.getElementById('modal-root').insertAdjacentHTML('beforeend', html);
    this._stack.push(modalId);
    document.body.style.overflow = 'hidden';
    return modalId;
  },

  close(id) {
    const el = document.getElementById(id);
    if (el) el.remove();
    this._stack = this._stack.filter(i => i !== id);
    if (this._stack.length === 0) document.body.style.overflow = '';
  },

  closeAll() {
    this._stack.forEach(id => { const el = document.getElementById(id); if (el) el.remove(); });
    this._stack = [];
    document.body.style.overflow = '';
  },

  _overlayClick(e, id) {
    if (e.target === e.currentTarget) this.close(id);
  },

  confirm(msg, onConfirm) {
    const id = Modal.show({
      title: '<i class="fas fa-question-circle text-warning"></i> تأكيد العملية',
      size: 'sm',
      body: `<p class="confirm-msg">${msg}</p>`,
      footer: `
        <button class="btn btn-secondary" onclick="Modal.close('${id}')">إلغاء</button>
        <button class="btn btn-danger" id="confirm-yes-${id}">تأكيد</button>`
    });
    setTimeout(() => {
      const btn = document.getElementById(`confirm-yes-${id}`);
      if (btn) btn.onclick = () => { Modal.close(id); onConfirm(); };
    }, 10);
    return id;
  }
};

