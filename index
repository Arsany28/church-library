              if (typeof Loans !== 'undefined') {
                Loans._page = 1;
                Loans.applyFilters();
              }
              if (typeof BorrowersMgr !== 'undefined') {
                BorrowersMgr._page = 1;
                BorrowersMgr.applyFilters();
              }
              if (typeof Dashboard !== 'undefined') {
                Dashboard.render();
              }
              if (typeof UI !== 'undefined') {
                UI.checkOverdueAlert();
                UI.navigate('dashboard');
              }
              
              Toast.warning('تم مسح جميع البيانات بنجاح');
              Loader.hide();
            }, 600);
          }
        );
      }
    );
  }
