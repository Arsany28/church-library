<script>
'use strict';

/* ============================================================
   API CONFIGURATION & ROUTING
============================================================ */
const API_URL = 'https://script.google.com/macros/s/AKfycbyJsqFD7TIs8UTJ8a4BCXjEZlMQjf0VqG0ecWT8VcoFXZXqwB-9UDA9PEoZEnyypmOx/exec';

const API = {
  async request(action, payload = {}) {
    try {
      const response = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify({ action, ...payload })
      });
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      const res = await response.json();
      if (res.status === 'error') {
        throw new Error(res.message || 'حدث خطأ غير معروف في الـ API');
      }
      return res.data;
    } catch (err) {
      console.error('API call failed:', err);
      throw err;
    }
  },

  async getAll() {
    return this.request('getAll');
  },

  async saveAll(data) {
    return this.request('saveAll', { data });
  }
};

/* ============================================================
   STORAGE MODULE (Using sessionStorage for UI preferences only)
============================================================ */
const Storage = {
  get: (key, fallback = null) => {
    try {
      const v = sessionStorage.getItem(key);
      return v !== null ? JSON.parse(v) : fallback;
    } catch { return fallback; }
  },
  set: (key, value) => {
    try { sessionStorage.setItem(key, JSON.stringify(value)); return true; }
    catch (e) { console.error('Storage error:', e); return false; }
  },
  remove: (key) => sessionStorage.removeItem(key),
  size: () => {
    let total = 0;
    for (const k in sessionStorage) {
      if (sessionStorage.hasOwnProperty(k)) total += (sessionStorage.getItem(k) || '').length * 2;
    }
    return total;
  }
};

/* ============================================================
   DYNAMIC CATEGORY TO LETTER MAP
============================================================ */
let CATEGORY_MAP = {};
let REVERSE_CATEGORY_MAP = {};

/* ============================================================
   DATA STORE (Synchronous memory arrays synchronized asynchronously)
============================================================ */
const Store = {
  books:     [],
  loans:     [],
  borrowers: [],
  categories: [],

  KEYS: { books: 'clib_books', loans: 'clib_loans', borrowers: 'clib_borrowers', settings: 'clib_settings' },

  async load() {
    UI.updateSyncStatus('loading', 'جاري جلب البيانات...');
    try {
      const data = await API.getAll();
      this.books = data.books || [];
      this.loans = data.loans || [];
      this.borrowers = data.borrowers || [];
      this.categories = data.categories || [
        { name: 'كتاب مقدس', letter: 'B' },
        { name: 'الآباء والقديسين', letter: 'F' },
        { name: 'لاهوت روحي', letter: 'ST' },
        { name: 'لاهوت عقيدي', letter: 'DT' },
        { name: 'طقوس', letter: 'LT' },
        { name: 'تاريخ كنيسة', letter: 'CH' },
        { name: 'تفاسير', letter: 'CM' },
        { name: 'سير وقديسين', letter: 'SB' },
        { name: 'فلسفة وعلم نفس', letter: 'PP' },
        { name: 'أسرة وطفل', letter: 'FC' },
        { name: 'عام', letter: 'GN' }
      ];
      if (data.settings && typeof Settings !== 'undefined') {
        Settings._current = { ...Settings._current, ...data.settings };
      }
      this.rebuildCategoryMaps();
      this.updateLoanStatuses(false); // don't trigger save during load
      UI.updateSyncStatus('success', 'متصل بالسحاب 🟢');
      return true;
    } catch (e) {
      console.error(e);
      UI.updateSyncStatus('error', 'غير متصل 🔴');
      Toast.error('فشل في تحميل البيانات من Google Sheets. تأكد من الاتصال بالإنترنت.');
      throw e;
    }
  },

  async save() {
    Loader.show('جاري حفظ البيانات في Google Sheets...');
    UI.updateSyncStatus('loading', 'جاري الحفظ...');
    try {
      await API.saveAll({
        books: this.books,
        loans: this.loans,
        borrowers: this.borrowers,
        categories: this.categories,
        settings: typeof Settings !== 'undefined' ? Settings.get() : {}
      });
      Loader.hide();
      UI.updateSyncStatus('success', 'متصل بالسحاب 🟢');
      return true;
    } catch (e) {
      Loader.hide();
      console.error(e);
      UI.updateSyncStatus('error', 'غير متصل 🔴');
      Toast.error('خطأ أثناء حفظ التعديلات: ' + e.message);
      return false;
    }
  },

  rebuildCategoryMaps() {
    CATEGORY_MAP = {};
    REVERSE_CATEGORY_MAP = {};
    this.categories.forEach(c => {
      CATEGORY_MAP[c.name] = c.letter.toUpperCase();
      REVERSE_CATEGORY_MAP[c.letter.trim().toLowerCase()] = c.name;
    });
  },

  updateLoanStatuses(triggerSave = true) {
    const today = new Date(); today.setHours(0,0,0,0);
    let changed = false;
    this.loans.forEach(l => {
      if (l.status === 'borrowed') {
        const ret = new Date(l.returnDate); ret.setHours(0,0,0,0);
        if (today > ret) { l.status = 'overdue'; changed = true; }
      }
    });
    if (changed && triggerSave) this.save();
  },

  getBook(id) { return this.books.find(b => b.id === id); },
  getLoan(id) { return this.loans.find(l => l.id === id); },
  getBorrower(name) { return this.borrowers.find(b => b.name.trim().toLowerCase() === name.trim().toLowerCase()); },

  stats() {
    const totalBooks     = this.books.length;
    const totalCopies    = this.books.reduce((s, b) => s + (b.copies || 0), 0);
    const availableBooks = this.books.filter(b => b.available > 0).length;
    const borrowedBooks  = this.books.filter(b => b.available < b.copies && b.available >= 0).length;
    const authors        = new Set(this.books.map(b => b.author).filter(Boolean)).size;
    const categories     = new Set(this.books.map(b => b.category).filter(Boolean)).size;
    const activeLoans    = this.loans.filter(l => l.status === 'borrowed' || l.status === 'overdue');
    const activeBorrowers = new Set(activeLoans.map(l => l.borrowerName)).size;
    const totalLoans     = this.loans.length;
    const overdue        = this.loans.filter(l => l.status === 'overdue').length;
    return { totalBooks, totalCopies, availableBooks, borrowedBooks, authors, categories, activeBorrowers, totalLoans, overdue };
  },

  genId: () => Date.now().toString(36) + Math.random().toString(36).slice(2, 7),

  async clear() {
    this.books = []; 
    this.loans = []; 
    this.borrowers = [];
    await this.save();
  }
};

