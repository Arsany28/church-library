      () => {
        Modal.confirm(
          '<strong class="text-danger">تأكيد أخير!</strong><br><br>لا يمكن التراجع عن هذا الإجراء.<br>هل تريد الاستمرار؟',
          () => {
            Loader.show('جاري المسح...');
            setTimeout(() => {
              Store.clear();
              
              // Reset and refresh all views
              if (typeof Books !== 'undefined') {
                Books.clearForm();
                Books.render();
